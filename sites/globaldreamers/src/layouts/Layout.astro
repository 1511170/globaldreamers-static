---
import siteConfig from '../../config/site.config.ts';
import '../styles/global.css';
import '../styles/animations.css';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import SEOHead from '../components/SEOHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  noindex?: boolean;
  keywords?: string[];
  // Schema.org props
  schemaType?: string[];
  schemaData?: Record<string, any>;
  breadcrumbs?: Array<{name: string; url: string}>;
  faqs?: Array<{q: string; a: string}>;
  howToName?: string;
  howToDescription?: string;
  steps?: Array<{name: string; text: string; url?: string}>;
}

const {
  title = siteConfig.site.name,
  description = siteConfig.site.description,
  canonical = Astro.url.href,
  image = '/og-image.webp',
  type = 'website',
  publishedTime,
  modifiedTime,
  author = siteConfig.site.name,
  noindex = false,
  keywords = [],
  // Schema defaults
  schemaType = ['Organization', 'WebSite'],
  schemaData = {},
  breadcrumbs,
  faqs,
  howToName,
  howToDescription,
  steps,
} = Astro.props;

const siteName = siteConfig.site.name;
const siteUrl = `https://${siteConfig.site.domain}`;
const fullImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

// Organization data para Schema.org
const organizationData = {
  name: 'Global Dreamers',
  url: siteUrl,
  logo: `${siteUrl}/images/logo-globaldreamers-color.png`,
  sameAs: [
    'https://facebook.com/globaldreamers',
    'https://instagram.com/globaldreamers',
    'https://linkedin.com/company/globaldreamers',
    'https://youtube.com/@globaldreamers',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+61-449-159-849',
    contactType: 'Customer Service',
    availableLanguage: ['Spanish', 'English'],
    areaServed: ['AU', 'CO', 'MX', 'CL', 'AR', 'PE', 'EC', 'PA'],
  },
  description: 'Agencia internacional de educación y viajes especializada en enviar estudiantes latinos a estudiar y trabajar en Australia, Canadá, Malta, Dubai, Reino Unido, Nueva Zelanda, Irlanda, España, Alemania, Italia y Estados Unidos.',
  foundingDate: '2018',
  address: {
    '@type': 'PostalAddress',
    addressCountry: 'AU',
    addressLocality: 'Sydney',
    addressRegion: 'NSW',
  },
};

// WebSite data
const websiteData = {
  name: siteName,
  url: siteUrl,
  description: siteConfig.site.description,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/buscar?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

// Merge schema data
const finalSchemaData = {
  ...organizationData,
  ...websiteData,
  ...schemaData,
};
---

<!DOCTYPE html>
<html lang={siteConfig.site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO + AI Citations Component -->
    <SEOHead 
      title={title}
      description={description}
      canonical={canonical}
      image={fullImage}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      noindex={noindex}
      keywords={keywords}
    />

    <!-- Schema.org Structured Data -->
    <SchemaOrg 
      type={schemaType}
      data={finalSchemaData}
      breadcrumbs={breadcrumbs}
      faqs={faqs}
      howToName={howToName}
      howToDescription={howToDescription}
      steps={steps}
    />

    <!-- AI Citations -->
    <link rel="alternate" type="text/plain" href="/llms.txt" />

    <!-- Google Fonts: Inter + Material Symbols Outlined -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <!-- Favicon -->
    {siteConfig.site.favicon && (
      <link rel="icon" type="image/x-icon" href={siteConfig.site.favicon} />
    )}

    <!-- GSAP for Premium Animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js" is:inline></script>
    
    <!-- Alpine.js for Reactive Components -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <!-- Skills inyectan meta tags, schemas, scripts -->
    <slot name="head" />
  </head>
  <body class="bg-white font-display text-slate-900 antialiased">
    <slot />
    <WhatsAppFloat />
    
    <!-- Animaciones Globales -->
    <script src="/scripts/animations.js" is:inline></script>
  </body>
</html>
