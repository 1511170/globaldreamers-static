---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { destinations } from '../data/destinations';

const title = 'Elige tu Destino Ideal | Global Dreamers';
const description = 'Descubre el país perfecto para tu experiencia internacional. Compara 11 destinos y encuentra el ideal para estudiar, trabajar y vivir en el exterior.';
const keywords = ['destinos para estudiar en el exterior', 'elegir país para estudiar', 'estudiar en australia', 'estudiar en canada', 'estudiar en europa'];

const countryCodes: Record<string, string> = {
  'canada': 'ca', 'malta': 'mt', 'dubai': 'ae', 'reino-unido': 'gb',
  'nueva-zelanda': 'nz', 'irlanda': 'ie', 'espana': 'es', 'alemania': 'de',
  'italia': 'it', 'estados-unidos': 'us', 'australia': 'au',
};

const sortedDestinations = [...destinations].sort((a, b) => a.name.localeCompare(b.name, 'es'));
---

<Layout
  title={title}
  description={description}
  canonical="/elige-tu-destino"
  keywords={keywords}
>
  <Navbar />

  <main>
    <!-- Hero -->
    <section class="relative py-20 lg:py-28 bg-slate-900 overflow-hidden">
      <div class="absolute inset-0 opacity-20">
        <img src="/images/hero.webp" alt="" class="w-full h-full object-cover" loading="eager" />
      </div>
      <div class="absolute inset-0 bg-gradient-to-b from-slate-900/80 to-slate-900"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">
          Elige tu <span class="text-primary">Destino Ideal</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-300 max-w-2xl mx-auto">
          Descubre el país perfecto para tu experiencia internacional. Compara destinos, conoce requisitos y empieza tu viaje.
        </p>
      </div>
    </section>

    <!-- Destinations Grid -->
    <section class="py-20 px-4 bg-slate-50">
      <div class="max-w-7xl mx-auto">
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedDestinations.map((dest) => (
            <a
              href={`/estudiar-en-${dest.country}/planner`}
              class="group relative h-72 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300"
            >
              <img
                src={dest.heroBg}
                alt={dest.name}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <div class="flex items-center gap-3 mb-2">
                  <img
                    src={`https://kapowaz.github.io/circle-flags/flags/${countryCodes[dest.country] || 'un'}.svg`}
                    alt={dest.name}
                    class="w-8 h-8 rounded-full"
                    loading="lazy"
                  />
                  <h3 class="text-2xl font-bold text-white">{dest.name}</h3>
                </div>
                <p class="text-sm text-white/80 mb-3 line-clamp-2">{dest.heroSubtitle}</p>
                <span class="inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-primary bg-white/10 backdrop-blur-sm px-3 py-1 rounded-full">
                  {dest.heroBadge}
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-4 bg-white">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
          ¿No sabes cuál elegir?
        </h2>
        <p class="text-slate-600 mb-8 text-lg">
          Nuestros asesores te ayudan a encontrar el destino perfecto según tu perfil, presupuesto y metas.
        </p>
        <a
          href="/asesoria-gratuita"
          class="inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg shadow-xl shadow-primary/30 hover:shadow-2xl hover:shadow-primary/40 transition-all"
        >
          <span class="material-symbols-outlined">support_agent</span>
          Asesoría Gratuita
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
