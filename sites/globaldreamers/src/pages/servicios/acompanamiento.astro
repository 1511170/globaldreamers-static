---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const title = 'Acompañamiento en tu Viaje | Global Dreamers';
const description = 'No estás solo. Te acompañamos desde tu país de origen hasta tu llegada al destino. Aeropuerto, instalación y primeros pasos en tu nueva ciudad.';
const keywords = [
  'acompañamiento viaje estudio',
  'recogida aeropuerto',
  'orientación estudiantes',
  'instalación en destino',
  'support international students',
  'bienvenida estudiantes',
];

// FAQs
const faqs = [
  {
    q: '¿Me recogen en el aeropuerto?',
    a: 'Sí, coordinamos tu recogida en el aeropuerto con un representante local que te llevará directo a tu alojamiento. Disponible 24/7 sin costo extra.'
  },
  {
    q: '¿Qué pasa si mi vuelo se retrasa?',
    a: 'Monitoreamos tu vuelo en tiempo real. Si hay cambios, ajustamos la recogida automáticamente y mantenemos comunicación constante.'
  },
  {
    q: '¿Me ayudan a abrir una cuenta bancaria?',
    a: 'Sí, te guiamos en el proceso de apertura de cuenta, obtención de SIM card local, y orientación sobre transporte público en tu primera semana.'
  },
  {
    q: '¿Hay soporte después de la llegada?',
    a: 'Absolutamente. Estamos disponibles 24/7 durante todo tu programa. Cualquier emergencia o duda, puedes contactarnos en cualquier momento.'
  },
];

// Servicios de acompañamiento
const supportServices = [
  { icon: 'flight_land', title: 'Recogida Aeropuerto', desc: 'Te esperamos a tu llegada y traslado seguro a tu alojamiento' },
  { icon: 'meeting_room', title: 'Orientación de Bienvenida', desc: 'Sesión informativa sobre tu ciudad, transporte y costumbres locales' },
  { icon: 'account_balance', title: 'Trámites Iniciales', desc: 'Apertura de cuenta bancaria, SIM card, y registro local si aplica' },
  { icon: 'map', title: 'Tour de la Ciudad', desc: 'Recorrido guiado mostrándote puntos clave: supermercados, farmacias, transporte' },
  { icon: 'school', title: 'Acompañamiento a Campus', desc: 'Te llevamos el primer día y te ayudamos con la matrícula e inducción' },
  { icon: 'support_agent', title: 'Línea de Emergencia', desc: 'Número local de contacto 24/7 para cualquier eventualidad' },
];

// Timeline del acompañamiento
const timeline = [
  { phase: 'Antes de viajar', items: ['Pre-departure briefing', 'Checklist de documentos', 'Contacto con familia anfitriona (si aplica)'] },
  { phase: 'Día de llegada', items: ['Recogida aeropuerto', 'Traslado alojamiento', 'Instalación y descanso'] },
  { phase: 'Primera semana', items: ['Orientación ciudad', 'Trámites bancarios', 'Tour institución', 'Inicio de clases'] },
  { phase: 'Durante tu estancia', items: ['Check-ins mensuales', 'Soporte continuo', 'Eventos comunitarios', 'Asesoría permanente'] },
];

// Estadísticas
const stats = [
  { value: '15+', label: 'Años de Experiencia' },
  { value: '50+', label: 'Ciudades Cubiertas' },
  { value: '24/7', label: 'Soporte Continuo' },
  { value: '100%', label: 'Estudiantes Acompañados' },
];

// Breadcrumbs
const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Servicios', url: '/servicios/' },
  { name: 'Acompañamiento', url: '/servicios/acompanamiento/' },
];
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
  canonical="/servicios/acompanamiento/"
  schemaType={['Organization', 'Service', 'BreadcrumbList', 'FAQPage']}
  schemaData={{
    name: 'Acompañamiento en tu Viaje - Global Dreamers',
    description: 'Servicio integral de acompañamiento para estudiantes internacionales desde su país de origen hasta su llegada al destino.',
    serviceType: 'Travel Support Services',
    provider: {
      '@type': 'Organization',
      name: 'Global Dreamers',
      url: 'https://globaldreamers.com.au',
    },
    areaServed: [
      { '@type': 'Country', name: 'Australia' },
      { '@type': 'Country', name: 'Canadá' },
      { '@type': 'Country', name: 'Reino Unido' },
      { '@type': 'Country', name: 'Irlanda' },
      { '@type': 'Country', name: 'Nueva Zelanda' },
      { '@type': 'Country', name: 'Malta' },
      { '@type': 'Country', name: 'Dubai' },
      { '@type': 'Country', name: 'España' },
      { '@type': 'Country', name: 'Alemania' },
      { '@type': 'Country', name: 'Italia' },
      { '@type': 'Country', name: 'Estados Unidos' },
    ],
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
      availability: 'https://schema.org/InStock',
      description: 'Consulta inicial gratuita para planificar tu acompañamiento',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '1200',
      bestRating: '5',
    },
  }}
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <Navbar ctaText="Quiero Acompañamiento" />
  
  <main class="flex-1">
    <!-- Hero Section -->
    <section class="relative overflow-hidden pt-16 pb-20 lg:pt-24 lg:pb-32 bg-white">
      <div class="absolute inset-0 z-0 opacity-10">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_50%,_#41c5f3_0%,_transparent_50%)]"></div>
      </div>
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 text-xs font-bold tracking-widest uppercase rounded-full w-fit" style="background-color: rgba(65, 197, 243, 0.1); color: #41c5f3;">
              <span class="material-symbols-outlined text-sm">flight_takeoff</span>
              Acompañamiento Personalizado
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6 text-slate-900">
              No estás <span style="color: #41c5f3;">solo</span>, te acompañamos en cada paso
            </h1>
            <p class="text-lg text-slate-600 mb-8 max-w-xl">
              Desde tu país de origen hasta tu llegada al destino. Recogida en aeropuerto, instalación en tu alojamiento y orientación completa para tus primeros días en tu nueva ciudad.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a 
                href="https://wa.me/61449159849?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20el%20servicio%20de%20acompa%C3%B1amiento"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 text-slate-900 px-8 py-4 rounded-xl font-bold text-lg hover:scale-105 transition-transform shadow-xl"
                style="background-color: #41c5f3; box-shadow: 0 20px 25px -5px rgba(65, 197, 243, 0.3), 0 8px 10px -6px rgba(65, 197, 243, 0.3);"
              >
                Solicitar Acompañamiento
                <span class="material-symbols-outlined">arrow_forward</span>
              </a>
              <a 
                href="#servicios"
                class="inline-flex items-center justify-center gap-2 border-2 border-slate-200 px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-50 transition-all"
              >
                Ver Servicios
              </a>
            </div>
          </div>
          <div class="relative">
            <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl bg-slate-100">
              <img 
                src="https://images.unsplash.com/photo-1436491865332-7a61a109cc05?w=800&h=800&fit=crop&q=80" 
                alt="Estudiante en aeropuerto internacional siendo recibido"
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
            <!-- Floating Trust Badge -->
            <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl border border-slate-100">
              <div class="flex items-center gap-4">
                <div class="p-3 rounded-full" style="background-color: rgba(65, 197, 243, 0.1);">
                  <span class="material-symbols-outlined" style="color: #41c5f3;">verified</span>
                </div>
                <div>
                  <div class="text-2xl font-bold text-slate-900">24/7</div>
                  <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Soporte Continuo</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar / Stats -->
    <section class="py-12 border-y" style="background-color: #0f172a; border-color: #1e293b;">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="text-3xl font-bold mb-1" style="color: #41c5f3;">{stat.value}</div>
              <div class="text-sm font-medium text-slate-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Support Services Grid -->
    <section id="servicios" class="py-20 lg:py-24 bg-slate-50">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Servicios de Acompañamiento</h2>
          <p class="text-slate-600 max-w-2xl mx-auto">Todo lo que necesitas para una llegada tranquila y segura a tu destino de estudios.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {supportServices.map((service) => (
            <div class="p-6 bg-white rounded-2xl shadow-sm border border-slate-200 hover:shadow-lg transition-all group" style="--tw-border-opacity: 1; border-color: rgb(226 232 240);">
              <div class="size-14 flex items-center justify-center rounded-xl mb-5 transition-all" style="background-color: rgba(65, 197, 243, 0.1);">
                <span class="material-symbols-outlined text-3xl transition-colors" style="color: #41c5f3;">{service.icon}</span>
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-2">{service.title}</h3>
              <p class="text-slate-600">{service.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Timeline/Phases Section -->
    <section class="py-20 lg:py-24 bg-white">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Tu Acompañamiento Paso a Paso</h2>
          <p class="text-slate-600">Una estructura clara para que sepas exactamente qué esperar en cada etapa de tu viaje.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {timeline.map((phase, idx) => (
            <div class="relative">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-xl shadow-lg" style="background-color: #41c5f3; color: #0f172a; box-shadow: 0 10px 15px -3px rgba(65, 197, 243, 0.3);">
                  {idx + 1}
                </div>
                <h3 class="text-xl font-bold text-slate-900">{phase.phase}</h3>
              </div>
              <ul class="space-y-3 ml-16">
                {phase.items.map((item) => (
                  <li class="flex items-start gap-2 text-slate-600">
                    <span class="material-symbols-outlined text-sm mt-1" style="color: #41c5f3;">check_circle</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              {idx < timeline.length - 1 && (
                <div class="hidden lg:block absolute top-6 left-[120px] w-full h-0.5" style="background: linear-gradient(to right, #41c5f3, transparent);"></div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial Section -->
    <section class="py-20 lg:py-24" style="background-color: rgba(65, 197, 243, 0.05);">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <span class="material-symbols-outlined text-6xl" style="color: #41c5f3;">format_quote</span>
          </div>
          <blockquote class="text-center">
            <p class="text-2xl md:text-3xl font-medium text-slate-900 mb-8 leading-relaxed">
              "Llegar a Australia sola me daba mucho miedo, pero desde que salí de Colombia me sentí acompañada. Me recogieron en el aeropuerto, me ayudaron con la tarjeta SIM y el banco. El primer día en la universidad no me sentí perdida gracias a ellos."
            </p>
            <footer class="flex items-center justify-center gap-4">
              <img 
                src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop&q=80" 
                alt="Mariana Gómez - Estudiante en Australia"
                class="w-16 h-16 rounded-full object-cover"
              />
              <div class="text-left">
                <cite class="not-italic font-bold text-slate-900">Mariana Gómez</cite>
                <p class="text-sm text-slate-500">Estudiante de Negocios • Sydney, Australia</p>
              </div>
            </footer>
          </blockquote>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-20 lg:py-24 bg-white">
      <div class="max-w-[800px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Preguntas Frecuentes</h2>
          <p class="text-slate-600">Todo lo que necesitas saber sobre nuestro servicio de acompañamiento</p>
        </div>
        <div class="space-y-4">
          {faqs.map((faq, idx) => (
            <details class="group border border-slate-200 rounded-xl bg-slate-50 p-6" open={idx === 0}>
              <summary class="flex justify-between items-center font-bold cursor-pointer list-none text-slate-900">
                {faq.q}
                <span class="material-symbols-outlined group-open:rotate-180 transition-transform">expand_more</span>
              </summary>
              <p class="mt-4 text-slate-600">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20">
      <div class="max-w-[900px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="rounded-3xl p-8 lg:p-16 text-center text-white relative overflow-hidden shadow-2xl" style="background-color: #0f172a;">
          <div class="absolute inset-0 opacity-5 mix-blend-overlay" style="background-color: #41c5f3;"></div>
          <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full blur-3xl" style="background-color: rgba(65, 197, 243, 0.2);"></div>
          <div class="absolute -bottom-20 -left-20 w-64 h-64 rounded-full blur-3xl" style="background-color: rgba(65, 197, 243, 0.1);"></div>
          
          <h2 class="text-3xl md:text-5xl font-black mb-6 relative z-10">¿Listo para viajar con tranquilidad?</h2>
          <p class="text-slate-300 text-lg mb-10 max-w-2xl mx-auto relative z-10">Agenda una cita con nuestros asesores y asegura tu acompañamiento completo desde el primer día.</p>
          <div class="flex flex-col sm:flex-row justify-center gap-4 relative z-10">
            <a 
              href="https://wa.me/61449159849?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20el%20servicio%20de%20acompa%C3%B1amiento"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 text-slate-900 px-10 py-5 rounded-xl font-bold text-lg hover:brightness-110 transition-all shadow-lg"
              style="background-color: #41c5f3; box-shadow: 0 10px 15px -3px rgba(65, 197, 243, 0.2);">
              <span class="material-symbols-outlined">calendar_today</span>
              Agendar Consultoría Ahora
            </a>
            <a 
              href="https://wa.me/61449159849?text=Hola%2C%20tengo%20preguntas%20sobre%20el%20acompa%C3%B1amiento"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white/30 text-white px-10 py-5 rounded-xl font-bold text-lg hover:bg-white/10 transition-all"
            >
              <span class="material-symbols-outlined">chat</span>
              Hablar por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
