---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const title = 'Alojamiento para Estudiantes | Global Dreamers';
const description = 'Encuentra el alojamiento perfecto para tu experiencia de estudio en el exterior. Homestay, residencias estudiantiles y apartamentos compartidos verificados.';
const keywords = [
  'alojamiento estudiantil',
  'homestay australia',
  'residencia estudiantil canada',
  'apartamento estudiantes',
  'alojamiento irlanda',
  'housing international students',
];

// FAQs
const faqs = [
  {
    q: '¿Qué tipo de alojamiento me conviene más?',
    a: 'Depende de tu presupuesto y estilo de vida: Homestay es ideal para inmersión cultural y practicar idioma, residencias son perfectas para socializar, y apartamentos ofrecen más independencia.'
  },
  {
    q: '¿El alojamiento está cerca de la institución?',
    a: 'Buscamos opciones dentro de 30-45 minutos en transporte público. La proximidad varía según la ciudad y presupuesto, siempre priorizando seguridad y accesibilidad.'
  },
  {
    q: '¿Qué incluye el alojamiento?',
    a: 'Generalmente incluye habitación amueblada, acceso a cocina/lavandería, wifi y servicios. Homestay suele incluir media pensión o pensión completa.'
  },
  {
    q: '¿Puedo cambiar de alojamiento si no me gusta?',
    a: 'Sí, dependiendo del contrato. La mayoría permite cambios con 2-4 semanas de aviso. Te ayudamos a gestionar el cambio si es necesario.'
  },
];

// Tipos de alojamiento
const accommodationTypes = [
  { icon: 'home', title: 'Homestay', desc: 'Vive con una familia local. Inmersión cultural total y práctica de idioma constante.', price: 'Desde $800/mes' },
  { icon: 'apartment', title: 'Residencia Estudiantil', desc: 'Habitación privada o compartida en campus o cerca. Ideal para socializar.', price: 'Desde $600/mes' },
  { icon: 'location_city', title: 'Apartamento Compartido', desc: 'Mayor independencia compartiendo con otros estudiantes internacionales.', price: 'Desde $500/mes' },
  { icon: 'hotel', title: 'Alojamiento Temporal', desc: 'Primeras semanas en hotel o hostel mientras encuentras algo permanente.', price: 'Desde $400/semana' },
];

// Features
const features = [
  { icon: 'verified', title: 'Alojamientos Verificados', desc: 'Visitamos y validamos cada opción personalmente' },
  { icon: 'security', title: 'Zonas Seguras', desc: 'Solo zonas con buena reputación y acceso a transporte' },
  { icon: 'support_agent', title: 'Soporte 24/7', desc: 'Asistencia permanente durante tu estadía' },
  { icon: 'local_atm', title: 'Sin Costos Ocultos', desc: 'Precios transparentes, sin cargos sorpresa' },
];

// Pasos del proceso
const steps = [
  {
    icon: 'search',
    title: 'Evaluamos tus Necesidades',
    desc: 'Analizamos tu presupuesto, ubicación preferida y estilo de vida para encontrar la mejor opción.',
  },
  {
    icon: 'photo_library',
    title: 'Selección de Opciones',
    desc: 'Te presentamos opciones verificadas con fotos reales, descripciones detalladas y reseñas.',
  },
  {
    icon: 'contract',
    title: 'Reserva y Contrato',
    desc: 'Gestionamos la reserva, revisamos el contrato y coordinamos el depósito de seguridad.',
  },
  {
    icon: 'key',
    title: 'Check-in de Bienvenida',
    desc: 'Te acompañamos en el check-in y verificamos que todo esté listo para tu llegada.',
  },
];

// Estadísticas
const stats = [
  { value: '+5k', label: 'Estudiantes Alojados' },
  { value: '98%', label: 'Satisfacción' },
  { value: '15+', label: 'Ciudades' },
  { value: '24/7', label: 'Soporte' },
];

// Breadcrumbs
const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Servicios', url: '/servicios/' },
  { name: 'Alojamiento', url: '/servicios/alojamiento/' },
];
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
  canonical="/servicios/alojamiento/"
  schemaType={['Organization', 'Service', 'BreadcrumbList', 'FAQPage', 'HowTo']}
  schemaData={{
    name: 'Alojamiento para Estudiantes Global Dreamers',
    description: 'Servicio de búsqueda y gestión de alojamiento estudiantil para destinos internacionales incluyendo homestay, residencias y apartamentos.',
    serviceType: 'Accommodation Services',
    provider: {
      '@type': 'Organization',
      name: 'Global Dreamers',
      url: 'https://globaldreamers.com.au',
    },
    areaServed: [
      { '@type': 'Country', name: 'Australia' },
      { '@type': 'Country', name: 'Canadá' },
      { '@type': 'Country', name: 'Reino Unido' },
      { '@type': 'Country', name: 'Irlanda' },
      { '@type': 'Country', name: 'Nueva Zelanda' },
      { '@type': 'Country', name: 'Malta' },
    ],
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
      availability: 'https://schema.org/InStock',
      description: 'Asesoría gratuita para encontrar tu alojamiento ideal',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.8',
      reviewCount: '850',
      bestRating: '5',
    },
  }}
  breadcrumbs={breadcrumbs}
  faqs={faqs}
  howToName="Cómo encontrar alojamiento estudiantil con Global Dreamers"
  howToDescription="Guía paso a paso para encontrar y reservar tu alojamiento ideal en el exterior"
  steps={steps.map(s => ({ name: s.title, text: s.desc }))}
>
  <Navbar ctaText="Encontrar Alojamiento" />
  
  <main class="flex-1">
    <!-- Hero Section -->
    <section class="relative overflow-hidden pt-16 pb-20 lg:pt-24 lg:pb-32 bg-white">
      <div class="absolute inset-0 z-0 opacity-10">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_50%,_var(--color-primary)_0%,_transparent_50%)]"></div>
      </div>
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 text-xs font-bold tracking-widest uppercase bg-primary/10 text-primary rounded-full w-fit">
              <span class="material-symbols-outlined text-sm">home</span>
              Alojamiento Estudiantil
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6 text-slate-900">
              Tu <span class="text-primary">hogar</span> lejos de casa
            </h1>
            <p class="text-lg text-slate-600 mb-8 max-w-xl">
              Encuentra el alojamiento perfecto para tu experiencia de estudio en el exterior. Opciones verificadas, zonas seguras y soporte permanente.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a 
                href="https://wa.me/61449159849?text=Hola%2C%20quiero%20encontrar%20alojamiento%20para%20mis%20estudios"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg hover:scale-105 transition-transform shadow-xl shadow-primary/30"
              >
                Encontrar Mi Alojamiento
                <span class="material-symbols-outlined">arrow_forward</span>
              </a>
              <a 
                href="#tipos"
                class="inline-flex items-center justify-center gap-2 border-2 border-slate-200 px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-50 transition-all"
              >
                Ver Opciones
              </a>
            </div>
          </div>
          <div class="relative">
            <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl bg-slate-100">
              <img 
                src="/images/hero-students.png" 
                alt="Estudiante en su alojamiento internacional"
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
            <!-- Floating Trust Badge -->
            <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl border border-slate-100">
              <div class="flex items-center gap-4">
                <div class="bg-green-100 p-3 rounded-full">
                  <span class="material-symbols-outlined text-green-600">verified</span>
                </div>
                <div>
                  <div class="text-2xl font-bold text-slate-900">+5,000</div>
                  <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Estudiantes Alojados</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar / Stats -->
    <section class="bg-slate-900 py-12 border-y border-slate-800">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="text-3xl font-bold text-primary mb-1">{stat.value}</div>
              <div class="text-sm font-medium text-slate-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Accommodation Types Grid -->
    <section id="tipos" class="py-20 lg:py-24 bg-slate-50">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Tipos de Alojamiento</h2>
          <p class="text-slate-600 max-w-2xl mx-auto">Encuentra la opción que mejor se adapte a tu estilo de vida, presupuesto y metas de estudio.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {accommodationTypes.map((type) => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-slate-200 hover:border-primary/50 hover:shadow-lg transition-all group flex flex-col">
              <div class="w-14 h-14 flex items-center justify-center bg-primary/10 text-primary rounded-2xl mb-4 group-hover:bg-primary group-hover:text-white transition-colors">
                <span class="material-symbols-outlined text-3xl">{type.icon}</span>
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-2">{type.title}</h3>
              <p class="text-slate-600 text-sm mb-4 flex-1">{type.desc}</p>
              <div class="pt-4 border-t border-slate-100">
                <span class="text-primary font-bold">{type.price}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-20 lg:py-24 bg-white">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">¿Por qué elegirnos?</h2>
          <p class="text-slate-600 max-w-2xl mx-auto">Nos encargamos de que tu experiencia de alojamiento sea segura, cómoda y sin preocupaciones.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
          {features.map((feature) => (
            <div class="text-center group">
              <div class="w-16 h-16 mx-auto flex items-center justify-center bg-primary/10 text-primary rounded-2xl mb-4 group-hover:bg-primary group-hover:text-white transition-colors">
                <span class="material-symbols-outlined text-3xl">{feature.icon}</span>
              </div>
              <h3 class="text-lg font-bold text-slate-900 mb-2">{feature.title}</h3>
              <p class="text-slate-600 text-sm">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process/How it works -->
    <section class="py-20 lg:py-24 bg-slate-50">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Cómo Funciona</h2>
          <p class="text-slate-600">Te acompañamos en cada paso para encontrar tu hogar ideal</p>
        </div>
        <div class="relative">
          <div class="hidden lg:block absolute top-12 left-1/2 -ml-px w-0.5 h-[calc(100%-100px)] bg-slate-200"></div>
          <div class="space-y-12">
            {steps.map((step, idx) => (
              <div class={`relative flex flex-col lg:flex-row items-center lg:items-start group ${idx % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
                <div class={`lg:w-1/2 ${idx % 2 === 0 ? 'lg:pr-16 lg:text-right' : 'lg:pl-16'}`}>
                  <h3 class="text-2xl font-bold mb-2 text-slate-900">{step.title}</h3>
                  <p class="text-slate-600">{step.desc}</p>
                </div>
                <div class="flex items-center justify-center w-12 h-12 rounded-full bg-primary text-white font-bold text-xl z-10 my-4 lg:my-0 shadow-lg shadow-primary/30">
                  {idx + 1}
                </div>
                <div class={`lg:w-1/2 ${idx % 2 === 0 ? 'lg:pl-16' : 'lg:pr-16 lg:text-right'}`}>
                  <div class="p-4 bg-white rounded-xl shadow-sm border border-slate-200 inline-block group-hover:bg-primary/5 transition-colors">
                    <span class="material-symbols-outlined text-primary text-4xl">{step.icon}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-20 lg:py-24 bg-white">
      <div class="max-w-[800px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Preguntas Frecuentes</h2>
          <p class="text-slate-600">Todo lo que necesitas saber sobre nuestro servicio de alojamiento</p>
        </div>
        <div class="space-y-4">
          {faqs.map((faq, idx) => (
            <details class="group border border-slate-200 rounded-xl bg-slate-50 p-6" open={idx === 0}>
              <summary class="flex justify-between items-center font-bold cursor-pointer list-none text-slate-900">
                {faq.q}
                <span class="material-symbols-outlined group-open:rotate-180 transition-transform">expand_more</span>
              </summary>
              <p class="mt-4 text-slate-600">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20">
      <div class="max-w-[900px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-slate-900 rounded-3xl p-8 lg:p-16 text-center text-white relative overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-primary opacity-5 mix-blend-overlay"></div>
          <div class="absolute -top-20 -right-20 w-64 h-64 bg-primary/20 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
          
          <h2 class="text-3xl md:text-5xl font-black mb-6 relative z-10">¿Listo para encontrar tu hogar?</h2>
          <p class="text-slate-300 text-lg mb-10 max-w-2xl mx-auto relative z-10">Contacta con nuestros asesores hoy mismo y te ayudamos a encontrar el alojamiento perfecto para tu experiencia.</p>
          <div class="flex flex-col sm:flex-row justify-center gap-4 relative z-10">
            <a 
              href="https://wa.me/61449159849?text=Hola%2C%20quiero%20encontrar%20alojamiento%20para%20mis%20estudios"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-primary text-white px-10 py-5 rounded-xl font-bold text-lg hover:brightness-110 transition-all shadow-lg shadow-primary/20"
            >
              <span class="material-symbols-outlined">calendar_today</span>
              Agendar Asesoría Ahora
            </a>
            <a 
              href="https://wa.me/61449159849?text=Hola%2C%20tengo%20preguntas%20sobre%20alojamiento"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white/30 text-white px-10 py-5 rounded-xl font-bold text-lg hover:bg-white/10 transition-all"
            >
              <span class="material-symbols-outlined">chat</span>
              Hablar por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
