---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const title = 'Gestión de Visas Estudiante | Global Dreamers';
const description = '✅ Tramitamos tu visa estudiante con 99% de tasa de aprobación. Expertos en visas para Australia, Canadá, UK, Irlanda y más. ¡Asesoría gratuita!';
const keywords = [
  'gestión de visa estudiante',
  'tramite visa australia',
  'visa estudiante canada',
  'visa tier 4 reino unido',
  'visa estudiante irlanda',
  'asesoría visa estudiante',
  'aprobación visa',
  'documentos visa estudiante',
];

// FAQs específicas de visas
const faqs = [
  {
    q: '¿Cuánto tiempo toma el proceso de visa?',
    a: 'Depende del destino: Australia (2-4 semanas), Canadá (4-8 semanas), Reino Unido (3-6 semanas), Irlanda (4-8 semanas). Nosotros te damos un estimado específico según tu país de origen y destino elegido.'
  },
  {
    q: '¿Qué pasa si mi visa es rechazada?',
    a: 'Analizamos el motivo del rechazo y te ayudamos a presentar una nueva aplicación o apelación según corresponda. Nuestra tasa de reaprobación después de reaplicación es del 95%.'
  },
  {
    q: '¿Necesito tener la admisión de la universidad primero?',
    a: 'Sí, para la mayoría de visas estudiante necesitas una carta de admisión (Offer Letter o COE). Nosotros te ayudamos a obtenerla como parte de nuestro servicio integral.'
  },
  {
    q: '¿Cuánto dinero debo demostrar en mi cuenta?',
    a: 'Varía por destino: Australia (~AUD $24,000-30,000), Canadá (~CAD $20,000-25,000), UK (~£1,300-1,500/mes). Te calculamos el monto exacto según tu duración de estudios y destino.'
  },
  {
    q: '¿Puedo trabajar con visa estudiante?',
    a: 'Sí, la mayoría de países permiten trabajar medio tiempo: Australia (48h/2 semanas), Canadá (20h/semana), UK (20h/semana), Irlanda (20h/semana). Te explicamos todos los detalles.'
  },
];

// Documentos que gestionamos
const documents = [
  { icon: 'description', label: 'Formularios Oficiales' },
  { icon: 'translate', label: 'Traducciones Certificadas' },
  { icon: 'health_and_safety', label: 'Seguros Médicos' },
  { icon: 'flight_takeoff', label: 'Reservas de Vuelo' },
  { icon: 'hotel', label: 'Reservas de Alojamiento' },
  { icon: 'account_balance_wallet', label: 'Pruebas de Solvencia' },
];

// Pasos del proceso
const steps = [
  {
    icon: 'folder_shared',
    title: 'Recolección de Documentos',
    desc: 'Analizamos tu perfil y te solicitamos los documentos específicos para tu caso. Revisamos cada detalle para evitar rechazos.',
  },
  {
    icon: 'send',
    title: 'Envío de Solicitud',
    desc: 'Presentamos tu solicitud ante las autoridades consulares correspondientes, gestionando citas y pagos de tasas.',
  },
  {
    icon: 'celebration',
    title: 'Notificación de Aprobación',
    desc: 'Te informamos inmediatamente sobre el estado de tu visa y coordinamos la entrega de tu pasaporte visado.',
  },
];

// Estadísticas
const stats = [
  { value: '+15k', label: 'Visas Gestionadas' },
  { value: '50+', label: 'Países Destino' },
  { value: '24/7', label: 'Soporte Continuo' },
  { value: '99%', label: 'Tasa de Éxito' },
];

// Breadcrumbs
const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Servicios', url: '/servicios/' },
  { name: 'Gestión de Visas', url: '/servicios/gestion-de-visas/' },
];
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
  canonical="/servicios/gestion-de-visas/"
  schemaType={['Organization', 'Service', 'BreadcrumbList', 'FAQPage', 'HowTo']}
  schemaData={{
    name: 'Gestión de Visas Global Dreamers',
    description: 'Servicio profesional de gestión de visas estudiante para destinos como Australia, Canadá, Reino Unido, Irlanda y más.',
    serviceType: 'Visa Services',
    provider: {
      '@type': 'Organization',
      name: 'Global Dreamers',
      url: 'https://globaldreamers.com.au',
    },
    areaServed: [
      { '@type': 'Country', name: 'Australia' },
      { '@type': 'Country', name: 'Canadá' },
      { '@type': 'Country', name: 'Reino Unido' },
      { '@type': 'Country', name: 'Irlanda' },
      { '@type': 'Country', name: 'Nueva Zelanda' },
      { '@type': 'Country', name: 'Malta' },
    ],
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
      availability: 'https://schema.org/InStock',
      description: 'Evaluación inicial gratuita del caso de visa',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '1500',
      bestRating: '5',
    },
  }}
  breadcrumbs={breadcrumbs}
  faqs={faqs}
  howToName="Cómo gestionar tu visa estudiante con Global Dreamers"
  howToDescription="Guía paso a paso para tramitar tu visa de estudiante con éxito"
  steps={steps.map(s => ({ name: s.title, text: s.desc }))}
>
  <Navbar ctaText="Iniciar Trámite" />
  
  <main class="flex-1">
    <!-- Hero Section -->
    <section class="relative overflow-hidden pt-16 pb-20 lg:pt-24 lg:pb-32 bg-white">
      <div class="absolute inset-0 z-0 opacity-10">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_50%_50%,_var(--color-primary)_0%,_transparent_50%)]"></div>
      </div>
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 text-xs font-bold tracking-widest uppercase bg-primary/10 text-primary rounded-full w-fit">
              <span class="material-symbols-outlined text-sm">verified</span>
              Gestión de Visas Experta
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6 text-slate-900">
              Nosotros nos ocupamos del <span class="text-primary">papeleo</span>, tú de soñar
            </h1>
            <p class="text-lg text-slate-600 mb-8 max-w-xl">
              Eliminamos el estrés de los trámites migratorios. Nuestro equipo especializado garantiza una gestión impecable para que tu única preocupación sea preparar las maletas.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a 
                href="https://wa.me/61449159849?text=Hola%2C%20quiero%20iniciar%20mi%20tr%C3%A1mite%20de%20visa"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 bg-primary text-slate-900 px-8 py-4 rounded-xl font-bold text-lg hover:scale-105 transition-transform shadow-xl shadow-primary/30"
              >
                Solicitar Asesoría Gratuita
                <span class="material-symbols-outlined">arrow_forward</span>
              </a>
              <a 
                href="#documentos"
                class="inline-flex items-center justify-center gap-2 border-2 border-slate-200 px-8 py-4 rounded-xl font-bold text-lg hover:bg-slate-50 transition-all"
              >
                Ver Requisitos
              </a>
            </div>
          </div>
          <div class="relative">
            <div class="aspect-square rounded-3xl overflow-hidden shadow-2xl bg-slate-100">
              <img 
                src="/images/hero-students.png" 
                alt="Estudiante feliz en aeropuerto internacional"
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
            <!-- Floating Trust Badge -->
            <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl border border-slate-100">
              <div class="flex items-center gap-4">
                <div class="bg-green-100 p-3 rounded-full">
                  <span class="material-symbols-outlined text-green-600">verified</span>
                </div>
                <div>
                  <div class="text-2xl font-bold text-slate-900">99%</div>
                  <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Tasa de Aprobación</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar / Stats -->
    <section class="bg-slate-900 py-12 border-y border-slate-800">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {stats.map((stat) => (
            <div class="text-center">
              <div class="text-3xl font-bold text-primary mb-1">{stat.value}</div>
              <div class="text-sm font-medium text-slate-400">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Checklist of Documents -->
    <section id="documentos" class="py-20 lg:py-24 bg-slate-50">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Documentos que Gestionamos</h2>
          <p class="text-slate-600 max-w-2xl mx-auto">Te ayudamos a recopilar, validar y presentar toda la documentación necesaria según el tipo de visa y destino.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {documents.map((doc) => (
            <div class="flex items-center gap-4 p-6 bg-white rounded-2xl shadow-sm border border-slate-200 hover:border-primary/50 hover:shadow-md transition-all group">
              <div class="size-12 flex items-center justify-center bg-primary/10 text-primary rounded-xl group-hover:bg-primary group-hover:text-slate-900 transition-colors">
                <span class="material-symbols-outlined text-2xl">{doc.icon}</span>
              </div>
              <p class="font-bold text-slate-900">{doc.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Process Timeline -->
    <section class="py-20 lg:py-24 bg-white">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Nuestro Proceso Paso a Paso</h2>
          <p class="text-slate-600">Transparencia total desde el primer contacto hasta que recibas tu aprobación.</p>
        </div>
        <div class="relative">
          <div class="hidden lg:block absolute top-12 left-1/2 -ml-px w-0.5 h-[calc(100%-100px)] bg-slate-200"></div>
          <div class="space-y-12">
            {steps.map((step, idx) => (
              <div class={`relative flex flex-col lg:flex-row items-center lg:items-start group ${idx % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
                <div class={`lg:w-1/2 ${idx % 2 === 0 ? 'lg:pr-16 lg:text-right' : 'lg:pl-16'}`}>
                  <h3 class="text-2xl font-bold mb-2 text-slate-900">{step.title}</h3>
                  <p class="text-slate-600">{step.desc}</p>
                </div>
                <div class="flex items-center justify-center w-12 h-12 rounded-full bg-primary text-slate-900 font-bold text-xl z-10 my-4 lg:my-0 shadow-lg shadow-primary/30">
                  {idx + 1}
                </div>
                <div class={`lg:w-1/2 ${idx % 2 === 0 ? 'lg:pl-16' : 'lg:pr-16 lg:text-right'}`}>
                  <div class="p-4 bg-slate-50 rounded-xl shadow-sm border border-slate-200 inline-block group-hover:bg-primary/5 transition-colors">
                    <span class="material-symbols-outlined text-primary text-4xl">{step.icon}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Countries Section -->
    <section class="py-20 lg:py-24 bg-slate-50">
      <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Destinos Populares</h2>
          <p class="text-slate-600">Gestionamos visas para los principales destinos de estudio</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          <a href="/estudiar-en-australia/" class="group p-6 bg-white rounded-2xl border border-slate-200 hover:border-primary/50 hover:shadow-lg transition-all text-center">
            <img src="https://kapowaz.github.io/circle-flags/flags/au.svg" alt="Australia" class="w-12 h-12 rounded-full mx-auto mb-3 object-cover" />
            <span class="font-bold text-slate-900 group-hover:text-primary transition-colors">Australia</span>
          </a>
          <a href="/estudiar-en-canada/" class="group p-6 bg-white rounded-2xl border border-slate-200 hover:border-primary/50 hover:shadow-lg transition-all text-center">
            <img src="https://kapowaz.github.io/circle-flags/flags/ca.svg" alt="Canadá" class="w-12 h-12 rounded-full mx-auto mb-3 object-cover" />
            <span class="font-bold text-slate-900 group-hover:text-primary transition-colors">Canadá</span>
          </a>
          <a href="/estudiar-en-reino-unido/" class="group p-6 bg-white rounded-2xl border border-slate-200 hover:border-primary/50 hover:shadow-lg transition-all text-center">
            <img src="https://kapowaz.github.io/circle-flags/flags/gb.svg" alt="Reino Unido" class="w-12 h-12 rounded-full mx-auto mb-3 object-cover" />
            <span class="font-bold text-slate-900 group-hover:text-primary transition-colors">Reino Unido</span>
          </a>
          <a href="/estudiar-en-irlanda/" class="group p-6 bg-white rounded-2xl border border-slate-200 hover:border-primary/50 hover:shadow-lg transition-all text-center">
            <img src="https://kapowaz.github.io/circle-flags/flags/ie.svg" alt="Irlanda" class="w-12 h-12 rounded-full mx-auto mb-3 object-cover" />
            <span class="font-bold text-slate-900 group-hover:text-primary transition-colors">Irlanda</span>
          </a>
          <a href="/estudiar-en-nueva-zelanda/" class="group p-6 bg-white rounded-2xl border border-slate-200 hover:border-primary/50 hover:shadow-lg transition-all text-center">
            <img src="https://kapowaz.github.io/circle-flags/flags/nz.svg" alt="Nueva Zelanda" class="w-12 h-12 rounded-full mx-auto mb-3 object-cover" />
            <span class="font-bold text-slate-900 group-hover:text-primary transition-colors">Nueva Zelanda</span>
          </a>
          <a href="/estudiar-en-malta/" class="group p-6 bg-white rounded-2xl border border-slate-200 hover:border-primary/50 hover:shadow-lg transition-all text-center">
            <img src="https://kapowaz.github.io/circle-flags/flags/mt.svg" alt="Malta" class="w-12 h-12 rounded-full mx-auto mb-3 object-cover" />
            <span class="font-bold text-slate-900 group-hover:text-primary transition-colors">Malta</span>
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-20 lg:py-24 bg-white">
      <div class="max-w-[800px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Preguntas Frecuentes</h2>
          <p class="text-slate-600">Todo lo que necesitas saber sobre el proceso de visa</p>
        </div>
        <div class="space-y-4">
          {faqs.map((faq, idx) => (
            <details class="group border border-slate-200 rounded-xl bg-slate-50 p-6" open={idx === 0}>
              <summary class="flex justify-between items-center font-bold cursor-pointer list-none text-slate-900">
                {faq.q}
                <span class="material-symbols-outlined group-open:rotate-180 transition-transform">expand_more</span>
              </summary>
              <p class="mt-4 text-slate-600">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20">
      <div class="max-w-[900px] mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-slate-900 rounded-3xl p-8 lg:p-16 text-center text-white relative overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-primary opacity-5 mix-blend-overlay"></div>
          <div class="absolute -top-20 -right-20 w-64 h-64 bg-primary/20 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-primary/10 rounded-full blur-3xl"></div>
          
          <h2 class="text-3xl md:text-5xl font-black mb-6 relative z-10">¿Listo para empezar tu próxima aventura?</h2>
          <p class="text-slate-300 text-lg mb-10 max-w-2xl mx-auto relative z-10">Agenda una cita con nuestros asesores hoy mismo y asegura tu éxito en el proceso de visa.</p>
          <div class="flex flex-col sm:flex-row justify-center gap-4 relative z-10">
            <a 
              href="https://wa.me/61449159849?text=Hola%2C%20quiero%20iniciar%20mi%20tr%C3%A1mite%20de%20visa"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-primary text-slate-900 px-10 py-5 rounded-xl font-bold text-lg hover:brightness-110 transition-all shadow-lg shadow-primary/20"
            >
              <span class="material-symbols-outlined">calendar_today</span>
              Agendar Consultoría Ahora
            </a>
            <a 
              href="https://wa.me/61449159849?text=Hola%2C%20tengo%20preguntas%20sobre%20el%20tr%C3%A1mite%20de%20visa"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-white/30 text-white px-10 py-5 rounded-xl font-bold text-lg hover:bg-white/10 transition-all"
            >
              <span class="material-symbols-outlined">chat</span>
              Hablar por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
