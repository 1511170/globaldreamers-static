      <script is:inline>
        function currencyConverter() {
          return {
            selectedCountry: 'LOCAL',
            isLoading: true,
            lastUpdated: null,
            rateSource: 'cargando...',
            
            // Tasas base (fallback)
            rates: {
              LOCAL: 1,
              CL: 920,      // Se actualizará desde API
              CO: 3691,     // Se actualizará desde API
              EC: 1,
              MX: 20.1,     // Se actualizará desde API
              PA: 1,
            },
            
            symbols: {
              LOCAL: { sym: '', suffix: '' },
              CL: { sym: '$', suffix: ' CLP' },
              CO: { sym: '$', suffix: ' COP' },
              EC: { sym: 'US$', suffix: '' },
              MX: { sym: '$', suffix: ' MXN' },
              PA: { sym: 'US$', suffix: '' },
            },
            
            destRates: {
              AUD: 1.56, CAD: 1.44, EUR: 0.93, GBP: 0.79, NZD: 1.72, USD: 1, AED: 3.67
            },
            
            async init() {
              await this.fetchRates();
            },
            
            async fetchRates() {
              try {
                // Intentar obtener tasas de API gratuita
                const response = await fetch('https://open.er-api.com/v6/latest/USD');
                
                if (!response.ok) throw new Error('API error');
                
                const data = await response.json();
                
                if (data.result === 'success' && data.rates) {
                  // Validar que las tasas son razonables
                  const cop = data.rates.COP;
                  const mxn = data.rates.MXN;
                  const clp = data.rates.CLP;
                  
                  // Solo actualizar si están en rangos razonables
                  if (cop >= 3000 && cop <= 5000) this.rates.CO = cop;
                  if (mxn >= 15 && mxn <= 30) this.rates.MX = mxn;
                  if (clp >= 700 && clp <= 1200) this.rates.CL = clp;
                  
                  this.lastUpdated = new Date(data.time_last_update_utc).toLocaleString('es-ES', {
                    day: 'numeric',
                    month: 'short',
                    hour: '2-digit',
                    minute: '2-digit'
                  });
                  this.rateSource = 'tiempo real';
                }
              } catch (error) {
                console.warn('[Currency] Using fallback rates:', error);
                this.rateSource = 'referencia';
                this.lastUpdated = '16 mar 2026';
              } finally {
                this.isLoading = false;
              }
            },
            
            async refreshRates() {
              this.isLoading = true;
              await this.fetchRates();
            },
            
            selectCountry(c) { 
              this.selectedCountry = c; 
            },
            
            getRateInfo() {
              if (this.selectedCountry === 'LOCAL') {
                return 'Mostrando precios en moneda local del destino';
              }
              
              const r = this.rates[this.selectedCountry];
              const s = this.symbols[this.selectedCountry];
              const rateStr = Math.round(r).toLocaleString();
              const sourceInfo = this.rateSource ? ` (${this.rateSource})` : '';
              
              return `Tasa: 1 USD = ${s.sym}${rateStr}${s.suffix}${sourceInfo}`;
            },
            
            getLastUpdateInfo() {
              if (!this.lastUpdated) return '';
              return `Actualizado: ${this.lastUpdated}`;
            },
            
            convertCost(str) {
              if (this.selectedCountry === 'LOCAL') return str;
              
              // Extraer número
              const num = str.replace(/,/g, '').match(/[\d.]+/);
              if (!num) return str;
              
              const amount = parseFloat(num[0]);
              
              // Detectar moneda origen
              let from = 1;
              if (str.includes('AUD')) from = this.destRates.AUD;
              else if (str.includes('CAD')) from = this.destRates.CAD;
              else if (str.includes('EUR') || str.includes('€')) from = this.destRates.EUR;
              else if (str.includes('GBP') || str.includes('£')) from = this.destRates.GBP;
              else if (str.includes('NZD')) from = this.destRates.NZD;
              else if (str.includes('AED')) from = this.destRates.AED;
              
              // Convertir
              const usd = amount / from;
              const conv = usd * this.rates[this.selectedCountry];
              
              // Formatear
              const fmt = this.symbols[this.selectedCountry];
              const val = Math.round(conv).toLocaleString('es-ES');
              const pref = str.includes('Desde') ? 'Desde ' : '';
              
              return `${pref}${fmt.sym}${val}${fmt.suffix}`;
            }
          }
        }
      </script>
