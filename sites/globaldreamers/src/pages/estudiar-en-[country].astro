---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { destinations } from '../data/destinations';
import type { DestinationData } from '../data/destinations';

export function getStaticPaths() {
  return destinations.map((dest) => ({
    params: { country: dest.country },
    props: { dest },
  }));
}

interface Props { dest: DestinationData }
const { dest } = Astro.props;

// Keywords por destino
const keywordsByCountry: Record<string, string[]> = {
  australia: ['estudiar en australia', 'trabajar en australia', 'visa australia estudiante', 'cursos en australia', 'sydney melbourne brisbane'],
  canada: ['estudiar en canada', 'work and study canada', 'study permit canada', 'pgwp canada', 'residencia permanente canada'],
  malta: ['estudiar ingles en malta', 'cursos de ingles malta', 'malta sin visa', 'estudiar en europa economico'],
  dubai: ['estudiar en dubai', 'trabajar en dubai', 'visa dubai', '0 impuestos dubai'],
  'reino-unido': ['estudiar en reino unido', 'estudiar en uk', 'graduate route visa', 'cursos en inglaterra'],
  'nueva-zelanda': ['estudiar en nueva zelanda', 'work and study new zealand', 'auckland wellington'],
  irlanda: ['estudiar en irlanda', 'work and study ireland', 'stay back visa irlanda', 'dublin cork'],
  espana: ['estudiar en españa', 'estudiar espanol en espana', 'nie espana estudiante', 'barcelona madrid'],
  alemania: ['estudiar en alemania', 'estudiar gratis en alemania', 'blocked account alemania', 'berlin munich'],
  italia: ['estudiar en italia', 'cursos de moda italia', 'estudiar italiano', 'roma milan'],
  'estados-unidos': ['estudiar en estados unidos', 'f1 visa usa', 'opt usa', 'trabajar en usa'],
};

const countryKeywords = keywordsByCountry[dest.country] || [];

// Cities data
const citiesCount = dest.cities?.length || 5;

// Schema.org data
const schemaData = {
  name: `Estudiar en ${dest.name}`,
  description: dest.heroSubtitle,
  url: `https://globaldreamers.com.au/estudiar-en-${dest.country}/`,
  areaServed: dest.name,
};

const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: dest.name, url: `/estudiar-en-${dest.country}/` },
];
---

<Layout 
  title={dest.seoTitle}
  description={dest.seoDescription}
  canonical={dest.canonical}
  type="website"
  keywords={[...countryKeywords, 'global dreamers', 'asesoría gratuita']}
  schemaType={['Organization', 'WebSite', 'Service']}
  schemaData={schemaData}
  breadcrumbs={breadcrumbs}
>
  <Navbar />
  
  <!-- Hero Section -->
  <section class="relative pt-20 pb-16 overflow-hidden" style="background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);">
    <div class="absolute inset-0 opacity-30">
      <img src={dest.heroBg} alt={dest.name} class="w-full h-full object-cover" loading="eager" />
    </div>
    <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-transparent"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="max-w-3xl">
        <span class="inline-block px-4 py-2 bg-primary/20 text-primary rounded-full text-sm font-semibold mb-6">
          {dest.heroBadge}
        </span>
        <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">
          {dest.heroTitle}
        </h1>
        <p class="text-xl text-slate-200 mb-8">
          {dest.heroSubtitle}
        </p>
        <div class="flex flex-col gap-4">
          <WhatsAppButton
            variant="destination"
            location={`hero-${dest.country}`}
            message={`Hola, quiero información para estudiar en ${dest.name}`}
            destinationCountry={dest.country}
            pageType="destination"
            size="lg"
            style="secondary"
            className="shadow-xl shadow-primary/30"
          >
            <span class="material-symbols-outlined">chat</span>
            Quiero Mi Asesoría GRATIS para {dest.name}
          </WhatsAppButton>
          
          <a 
            href={`/estudiar-en-${dest.country}/planner`}
            class="group relative overflow-hidden bg-gradient-to-r from-slate-800 to-slate-700 text-white px-8 py-4 rounded-xl font-bold hover:shadow-xl transition-all text-center"
          >
            <div class="absolute inset-0 bg-gradient-to-r from-brand-600 to-brand-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <span class="relative flex items-center justify-center gap-2">
              <span class="material-symbols-outlined">auto_awesome</span>
              <span>✨ Calcula tu Presupuesto - Planner Interactivo</span>
              <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </span>
          </a>
          
          <div class="flex items-center gap-3 text-slate-300 text-sm">
            <span class="material-symbols-outlined text-primary">check_circle</span>
            <span>{dest.heroStats}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pain Points -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12 text-slate-900">¿Te Sientes Así?</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {dest.painPoints.map((point) => (
          <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100">
            <div class={`w-14 h-14 rounded-xl ${point.colorBg} flex items-center justify-center mb-6`}>
              <svg class={`w-7 h-7 ${point.colorIcon}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={point.iconPath} />
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3 text-slate-900">{point.title}</h3>
            <p class="text-slate-600">{point.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-20 px-4 bg-slate-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12 text-slate-900">¿Por Qué Elegir {dest.name}?</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {dest.benefits.map((benefit) => (
          <div class={`bg-white rounded-2xl p-6 border-l-4 ${benefit.borderColor} shadow-sm`}>
            <div class={`w-12 h-12 rounded-lg ${benefit.bgColor} flex items-center justify-center mb-4`}>
              <svg class={`w-6 h-6 ${benefit.iconColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={benefit.iconPath} />
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-2 text-slate-900">{benefit.title}</h3>
            <p class="text-slate-600 text-sm">{benefit.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cities -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-4 text-slate-900">Ciudades Principales en {dest.name}</h2>
      <p class="text-center text-slate-500 mb-12">Elige la ciudad perfecta para tu experiencia</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {dest.cities.map((city) => (
          <div class="group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
            <img src={city.image} alt={city.name} class="w-full h-48 object-cover group-hover:scale-105 transition-transform" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-6 text-white">
              <h3 class="text-xl font-bold">{city.name}</h3>
              <p class="text-white/80 text-sm">{city.para}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Investment Table with Currency Converter -->
  <section class="py-24 px-4 bg-slate-50" id="costos" x-data="currencyConverter()">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-4 text-center text-slate-900">¿Cuánto Cuesta Estudiar en {dest.name}?</h2>
      <p class="text-center text-slate-500 mb-8">{dest.investmentCurrencyNote}</p>
      
      <!-- Currency Converter Controls -->
      <div class="bg-white rounded-2xl shadow-lg border border-slate-200 p-6 mb-8">
        <p class="text-sm font-semibold text-slate-600 mb-4 text-center">Selecciona tu país para ver los precios en tu moneda:</p>
        <div class="flex flex-wrap justify-center gap-3">
          <button 
            @click="selectCurrency('LOCAL')" 
            :class="selectedCurrency === 'LOCAL' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
            class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
          >
            <span class="font-medium text-sm">Moneda local ({dest.name})</span>
          </button>
          <button 
            @click="selectCurrency('COP')" 
            :class="selectedCurrency === 'COP' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
            class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
          >
            <img src="https://kapowaz.github.io/circle-flags/flags/co.svg" alt="Colombia" class="w-5 h-5 rounded-full" />
            <span class="font-medium text-sm">Colombia (COP)</span>
          </button>
          <button 
            @click="selectCurrency('MXN')" 
            :class="selectedCurrency === 'MXN' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
            class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
          >
            <img src="https://kapowaz.github.io/circle-flags/flags/mx.svg" alt="México" class="w-5 h-5 rounded-full" />
            <span class="font-medium text-sm">México (MXN)</span>
          </button>
          <button 
            @click="selectCurrency('CLP')" 
            :class="selectedCurrency === 'CLP' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
            class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
          >
            <img src="https://kapowaz.github.io/circle-flags/flags/cl.svg" alt="Chile" class="w-5 h-5 rounded-full" />
            <span class="font-medium text-sm">Chile (CLP)</span>
          </button>
          <button 
            @click="selectCurrency('USD')" 
            :class="selectedCurrency === 'USD' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
            class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
          >
            <img src="https://kapowaz.github.io/circle-flags/flags/us.svg" alt="USD" class="w-5 h-5 rounded-full" />
            <span class="font-medium text-sm">Ecuador/Panamá (USD)</span>
          </button>
        </div>
        
        <div class="mt-4 space-y-1 text-center">
          <p class="text-xs text-slate-500" x-text="getRateInfo()"></p>
          <p class="text-xs text-slate-400" x-text="getLastUpdateInfo()" x-show="lastUpdated"></p>
          <button 
            @click="refreshRates()"
            :disabled="isLoading"
            class="text-xs text-primary hover:text-primary/80 flex items-center gap-1 mx-auto mt-2 disabled:opacity-50"
          >
            <span x-show="isLoading">Actualizando...</span>
            <span x-show="!isLoading">🔄 Actualizar tasas</span>
          </button>
        </div>
      </div>

      <div class="bg-white rounded-3xl overflow-hidden shadow-xl border border-slate-200">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="p-6 font-bold text-slate-900">Concepto</th>
              <th class="p-6 font-bold text-right text-slate-900" x-text="selectedCurrency === 'LOCAL' ? 'Costo Estimado' : 'Costo en tu moneda'"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {dest.investmentRows.map((row) => (
              <tr>
                <td class="p-6 text-slate-700">{row.concept}</td>
                <td class="p-6 text-right font-medium text-slate-900 cost-cell" data-original-cost={row.cost} x-text="getCostDisplay($el.dataset.originalCost, selectedCurrency)">{row.cost}</td>
              </tr>
            ))}
            <tr class="bg-primary/5">
              <td class="p-6 font-bold text-primary">TOTAL ESTIMADO</td>
              <td class="p-6 text-right font-bold text-primary text-xl cost-cell" data-original-cost={dest.investmentTotal} x-text="getCostDisplay($el.dataset.originalCost, selectedCurrency)">{dest.investmentTotal}</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-8 text-sm text-center text-slate-400 italic">
        Los precios varían según la escuela, ciudad y duración del curso. 
        Tasas de cambio actualizadas automáticamente desde fuentes oficiales.
      </p>
    </div>

    <script is:inline>
      function currencyConverter() {
        return {
          selectedCurrency: 'LOCAL',
          isLoading: true,
          lastUpdated: null,
          rateSource: 'referencia',
          
          // Tasas respecto a USD
          rates: {
            LOCAL: 1,
            COP: 3691,
            MXN: 20.1,
            CLP: 920,
            USD: 1,
          },
          
          // Tasas de destinos
          destRates: {
            AUD: 1.56, CAD: 1.44, EUR: 0.93, GBP: 0.79, NZD: 1.72, USD: 1, AED: 3.67
          },
          
          // Símbolos
          symbols: {
            LOCAL: { sym: '', suffix: '' },
            COP: { sym: '$', suffix: ' COP' },
            MXN: { sym: '$', suffix: ' MXN' },
            CLP: { sym: '$', suffix: ' CLP' },
            USD: { sym: 'US$', suffix: '' },
          },
          
          init() {
            this.fetchRates();
          },
          
          async fetchRates() {
            try {
              const response = await fetch('https://open.er-api.com/v6/latest/USD');
              if (!response.ok) throw new Error('API error');
              
              const data = await response.json();
              
              if (data.result === 'success' && data.rates) {
                // Actualizar tasas con validación
                if (data.rates.COP >= 3000 && data.rates.COP <= 5000) {
                  this.rates.COP = data.rates.COP;
                }
                if (data.rates.MXN >= 15 && data.rates.MXN <= 30) {
                  this.rates.MXN = data.rates.MXN;
                }
                if (data.rates.CLP >= 700 && data.rates.CLP <= 1200) {
                  this.rates.CLP = data.rates.CLP;
                }
                
                this.lastUpdated = new Date().toLocaleString('es-ES', {
                  day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit'
                });
                this.rateSource = 'tiempo real';
              }
            } catch (error) {
              console.warn('[Currency] Usando tasas de referencia:', error);
            } finally {
              this.isLoading = false;
            }
          },
          
          async refreshRates() {
            this.isLoading = true;
            await this.fetchRates();
          },
          
          selectCurrency(curr) {
            this.selectedCurrency = curr;
          },
          
          getRateInfo() {
            if (this.selectedCurrency === 'LOCAL') {
              return 'Mostrando precios en moneda local del destino';
            }
            
            const r = this.rates[this.selectedCurrency];
            const s = this.symbols[this.selectedCurrency];
            const rateStr = Math.round(r).toLocaleString();
            return `Tasa referencia: 1 USD ≈ ${s.sym}${rateStr}${s.suffix} (${this.rateSource})`;
          },
          
          getLastUpdateInfo() {
            return this.lastUpdated ? `Actualizado: ${this.lastUpdated}` : '';
          },
          
          getCostDisplay(costStr, currency) {
            // El parámetro 'currency' fuerza re-evaluación cuando cambia selectedCurrency
            // Si es LOCAL, mostrar el costo original
            if (this.selectedCurrency === 'LOCAL') {
              return costStr;
            }
            
            // Extraer el número del costo
            const numMatch = costStr.match(/[\d,]+/);
            if (!numMatch) return costStr;
            
            const amount = parseFloat(numMatch[0].replace(/,/g, ''));
            if (isNaN(amount)) return costStr;
            
            // Detectar moneda de origen
            let fromRate = 1;
            if (costStr.includes('AUD')) fromRate = this.destRates.AUD;
            else if (costStr.includes('CAD')) fromRate = this.destRates.CAD;
            else if (costStr.includes('EUR') || costStr.includes('€')) fromRate = this.destRates.EUR;
            else if (costStr.includes('GBP') || costStr.includes('£')) fromRate = this.destRates.GBP;
            else if (costStr.includes('NZD')) fromRate = this.destRates.NZD;
            else if (costStr.includes('AED')) fromRate = this.destRates.AED;
            else if (costStr.includes('USD')) fromRate = this.destRates.USD;
            
            // Convertir: origen → USD → destino
            const usdAmount = amount / fromRate;
            const targetRate = this.rates[this.selectedCurrency];
            const converted = usdAmount * targetRate;
            
            // Formatear resultado
            const symbol = this.symbols[this.selectedCurrency];
            const formatted = Math.round(converted).toLocaleString('es-ES');
            const prefix = costStr.toLowerCase().includes('desde') ? 'Desde ' : '';
            
            return `${prefix}${symbol.sym}${formatted}${symbol.suffix}`;
          }
        }
      }
    </script>
  </section>

  <!-- FAQ Section -->
  <section class="py-24 px-4 bg-white" id="faq">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold mb-12 text-center text-slate-900">Preguntas Frecuentes sobre Estudiar en {dest.name}</h2>
      <div class="space-y-4">
        {dest.faqs.slice(0, 3).map((faq, idx) => (
          <details class="group border border-slate-200 rounded-xl bg-white p-6" open={idx === 0}>
            <summary class="flex justify-between items-center font-bold cursor-pointer list-none text-slate-900">
              {faq.q}
              <span class="material-symbols-outlined group-open:rotate-180 transition-transform">expand_more</span>
            </summary>
            <p class="mt-4 text-slate-600">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-24 px-4 relative overflow-hidden">
    <div class="absolute inset-0 bg-primary"></div>
    <div class="relative z-10 max-w-4xl mx-auto text-center text-white">
      <h2 class="text-4xl md:text-5xl font-black mb-6 leading-tight">
        {dest.ctaTitle}
      </h2>
      <p class="text-xl mb-10 opacity-90">{dest.ctaSubtext}</p>
      <div class="flex flex-col items-center gap-4">
        <WhatsAppButton
          variant="cta"
          location={`cta-final-${dest.country}`}
          message={`Hola, quiero solicitar mi asesoría gratuita para ${dest.name}`}
          destinationCountry={dest.country}
          pageType="destination"
          size="lg"
          style="outline"
          className="px-10 py-5 text-xl font-black shadow-2xl"
        >
          ¡Solicitar Mi Asesoría GRATIS Ahora!
        </WhatsAppButton>
        <p class="text-sm font-medium opacity-80 flex items-center gap-2">
          <span class="material-symbols-outlined text-sm">schedule</span> 
          Cupos limitados para asesorías esta semana
        </p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
