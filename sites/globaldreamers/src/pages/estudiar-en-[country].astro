---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { destinations } from '../data/destinations';
import type { DestinationData } from '../data/destinations';

export function getStaticPaths() {
  return destinations.map((dest) => ({
    params: { country: dest.country },
    props: { dest },
  }));
}

interface Props { dest: DestinationData }
const { dest } = Astro.props;

// Keywords por destino
const keywordsByCountry: Record<string, string[]> = {
  australia: ['estudiar en australia', 'trabajar en australia', 'visa australia estudiante', 'cursos en australia', 'sydney melbourne brisbane'],
  canada: ['estudiar en canada', 'work and study canada', 'study permit canada', 'pgwp canada', 'residencia permanente canada'],
  malta: ['estudiar ingles en malta', 'cursos de ingles malta', 'malta sin visa', 'estudiar en europa economico'],
  dubai: ['estudiar en dubai', 'trabajar en dubai', 'visa dubai', '0 impuestos dubai'],
  'reino-unido': ['estudiar en reino unido', 'estudiar en uk', 'graduate route visa', 'cursos en inglaterra'],
  'nueva-zelanda': ['estudiar en nueva zelanda', 'work and study new zealand', 'auckland wellington'],
  irlanda: ['estudiar en irlanda', 'work and study ireland', 'stay back visa irlanda', 'dublin cork'],
  espana: ['estudiar en españa', 'estudiar espanol en espana', 'nie espana estudiante', 'barcelona madrid'],
  alemania: ['estudiar en alemania', 'estudiar gratis en alemania', 'blocked account alemania', 'berlin munich'],
  italia: ['estudiar en italia', 'cursos de moda italia', 'estudiar italiano', 'roma milan'],
  'estados-unidos': ['estudiar en estados unidos', 'f1 visa usa', 'opt usa', 'trabajar en usa'],
};

const keywords = keywordsByCountry[dest.country] || ['estudiar en el exterior'];

// Definir cursos según el destino
const courses = [
  {
    title: 'Inglés General',
    desc: 'Perfecciona tu nivel desde principiante hasta avanzado con profesores nativos.',
    features: ['Desde 4 semanas', 'Enfoque comunicativo'],
    popular: false
  },
  {
    title: dest.country === 'canada' ? 'Co-op Work & Study' : 
            dest.country === 'australia' ? 'Cursos VET (Técnicos)' :
            dest.country === 'reino-unido' ? 'Cursos Profesionales' :
            'Cursos Vocacionales',
    desc: 'Especialízate mientras trabajas. Programas prácticos con alta empleabilidad.',
    features: ['Muy económicos', 'Horarios flexibles'],
    popular: true
  },
  {
    title: 'Universidad',
    desc: 'Grados y Masters con alta proyección migratoria y laboral.',
    features: ['Prestigio internacional', 'Post-study work visa'],
    popular: false
  }
];

// Pasos del proceso
const steps = [
  {
    num: '1',
    title: 'Planificación a Medida',
    desc: 'Elegimos el curso y la ciudad ideal según tu perfil y presupuesto. Sin costos ocultos.'
  },
  {
    num: '2',
    title: 'Gestión de Visa Exitosa',
    desc: 'Nuestros expertos revisan cada documento para garantizar una aprobación rápida y segura.'
  },
  {
    num: '3',
    title: 'Soporte en Destino',
    desc: `Te recibimos en ${dest.name}, te ayudamos con tu cuenta bancaria y a buscar tu primer empleo.`
  }
];

// Beneficios específicos según destino
const getBenefits = (country: string) => {
  const benefits: Record<string, Array<{icon: string, title: string, desc: string}>> = {
    australia: [
      { icon: 'payments', title: 'Salario Mínimo Alto', desc: 'Gana desde $23.23 AUD por hora. El país con mejor paga del mundo.' },
      { icon: 'work_history', title: 'Permiso de Trabajo', desc: 'Trabaja legalmente 48 horas quincenales mientras estudias.' },
      { icon: 'sunny', title: 'Calidad de Vida', desc: 'Ciudades seguras, playas increíbles y un clima espectacular.' },
      { icon: 'school', title: 'Educación Elite', desc: 'Instituciones de prestigio mundial reconocidas globalmente.' }
    ],
    canada: [
      { icon: 'payments', title: 'Camino a la PR', desc: 'Estudiar es la vía más directa a la residencia permanente.' },
      { icon: 'work_history', title: 'Trabajo Garantizado', desc: '20hrs/semana durante estudios + PGWP post-grado hasta 3 años.' },
      { icon: 'school', title: 'Educación Top', desc: 'Universidades en ranking mundial con programas en inglés y francés.' },
      { icon: 'sunny', title: 'Multicultural', desc: 'Comunidad latina enorme y bienvenida a inmigrantes.' }
    ],
    default: [
      { icon: 'payments', title: 'Inversión Inteligente', desc: 'Relación calidad-precio inmejorable en educación y vida.' },
      { icon: 'work_history', title: 'Trabajo Legal', desc: 'Permiso de trabajo mientras estudias para cubrir tus gastos.' },
      { icon: 'sunny', title: 'Experiencia Única', desc: 'Descubre una nueva cultura mientras avanzas profesionalmente.' },
      { icon: 'school', title: 'Educación de Calidad', desc: 'Instituciones reconocidas internacionalmente.' }
    ]
  };
  return benefits[country] || benefits.default;
};

const benefits = getBenefits(dest.country);

// Breadcrumbs
const breadcrumbs = [
  { name: 'Inicio', url: '/' },
  { name: 'Destinos', url: '/#destinos' },
  { name: dest.name, url: dest.canonical },
];

// FAQs para Schema.org
const faqsForSchema = dest.faqs.map(f => ({ q: f.q, a: f.a }));
---

<Layout
  title={dest.seoTitle}
  description={dest.seoDescription}
  canonical={dest.canonical}
  image={dest.heroBg}
  keywords={keywords}
  schemaType={['Organization', 'Service', 'BreadcrumbList', 'FAQPage']}
  schemaData={{
    name: `Estudiar en ${dest.name}`,
    description: dest.seoDescription,
    serviceType: 'Student Visa Consulting',
    provider: {
      '@type': 'Organization',
      name: 'Global Dreamers',
      url: 'https://globaldreamers.com.au',
    },
    areaServed: {
      '@type': 'Country',
      name: dest.name,
    },
    offers: {
      '@type': 'AggregateOffer',
      name: 'Programas de Estudio',
      description: 'Cursos de inglés, programas vocacionales y universitarios',
      lowPrice: dest.investmentRows[0]?.cost?.replace(/[^0-9]/g, '') || '0',
      priceCurrency: dest.country === 'canada' ? 'CAD' : dest.country === 'malta' || dest.country === 'irlanda' || dest.country === 'espana' || dest.country === 'alemania' || dest.country === 'italia' ? 'EUR' : dest.country === 'reino-unido' ? 'GBP' : 'AUD',
      availability: 'https://schema.org/InStock',
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '500',
      bestRating: '5',
    },
  }}
  breadcrumbs={breadcrumbs}
  faqs={faqsForSchema}
>
  <Navbar />
  
  <main>
    <!-- Hero Section -->
    <section class="relative min-h-[80vh] flex items-center pt-12 pb-20 px-4">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-r from-white via-white/90 to-transparent z-10"></div>
        <img 
          class="w-full h-full object-cover" 
          alt={`Estudiar en ${dest.name} - ${dest.heroBadge}`}
          src={dest.heroBg}
          loading="eager"
          fetchpriority="high"
          decoding="sync"
        />
      </div>
      <div class="relative z-20 max-w-7xl mx-auto w-full">
        <div class="max-w-2xl">
          <span class="inline-block py-1 px-3 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider mb-4 border border-primary/20">
            {dest.name} 2026
          </span>
          <h1 class="text-5xl md:text-7xl font-black leading-tight tracking-tight mb-6 text-slate-900">
            {dest.heroTitle.split('—')[0]} — <span class="text-primary">{dest.heroTitle.split('—')[1]?.trim() || dest.heroBadge}</span>
          </h1>
          <p class="text-lg md:text-xl text-slate-600 mb-8 leading-relaxed">
            Todo lo que necesitas para tu aventura en {dest.name}: gestión de visa, elección de curso y soporte personalizado en el destino. No camines solo.
          </p>
          <div class="flex flex-col gap-4">
            <!-- Primary CTA -->
            <WhatsAppButton
              variant="destination"
              location={`hero-${dest.country}`}
              message={`Hola, quiero información para estudiar en ${dest.name}`}
              destinationCountry={dest.country}
              pageType="destination"
              size="lg"
              style="secondary"
              className="shadow-xl shadow-primary/30"
            >
              <span class="material-symbols-outlined">chat</span>
              Quiero Mi Asesoría GRATIS para {dest.name}
            </WhatsAppButton>
            
            {/* Journey Builder Button - For all destinations */}
            <a 
              href={`/estudiar-en-${dest.country}/planner`}
              class="group relative overflow-hidden bg-gradient-to-r from-slate-900 to-slate-800 text-white px-8 py-4 rounded-xl font-bold hover:shadow-xl transition-all text-center"
            >
              <div class="absolute inset-0 bg-gradient-to-r from-brand-600 to-brand-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <span class="relative flex items-center justify-center gap-2">
                <span class="material-symbols-outlined">auto_awesome</span>
                <span>✨ Diseña tu vida en {dest.name} - Calculadora Interactiva</span>
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
              </span>
            </a>
            
            {/* Social Proof */}
            <div class="flex items-center gap-3 pt-2">
              <div class="flex -space-x-2">
                <img class="w-10 h-10 rounded-full border-2 border-white object-cover" alt="Estudiante en Australia" src="/images/testimonial-camila.png" loading="lazy" />
                <img class="w-10 h-10 rounded-full border-2 border-white object-cover" alt="Estudiante en Canadá" src="/images/testimonial-marcos.png" loading="lazy" />
                <img class="w-10 h-10 rounded-full border-2 border-white object-cover" alt="Estudiante en Malta" src="/images/testimonial-sofia.png" loading="lazy" />
              </div>
              <span class="text-sm font-medium text-slate-500">+500 estudiantes este mes</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem/Agitation Section -->
    <section class="py-24 bg-white">
      <div class="max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-12 text-slate-900">¿Te Identificas con Esto?</h2>
        <div class="grid gap-4">
          {dest.painPoints.map((point) => (
            <div class="flex items-center justify-between p-6 bg-slate-50 rounded-2xl border border-slate-100">
              <p class="text-lg font-medium text-slate-800">"{point.title}"</p>
              <svg class={`w-8 h-8 ${point.colorIcon}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={point.iconPath} />
              </svg>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Solution Section -->
    <section class="py-24 px-4 bg-primary/5">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-4xl font-black mb-4 text-slate-900">Global Dreamers Hace Todo Por Ti</h2>
          <p class="text-slate-600 max-w-2xl mx-auto text-lg">Simplificamos tu proceso en 3 pasos claros para que solo te preocupes por empacar.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
          {steps.map((step) => (
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-100">
              <div class="w-12 h-12 bg-primary text-white rounded-lg flex items-center justify-center font-bold text-xl mb-6">
                {step.num}
              </div>
              <h3 class="text-xl font-bold mb-3 text-slate-900">{step.title}</h3>
              <p class="text-slate-600 leading-relaxed">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Benefits Grid -->
    <section class="py-24 px-4 bg-white" id="beneficios">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold mb-12 text-center text-slate-900">¿Por qué {dest.name} es tu mejor opción?</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {dest.benefits.slice(0, 4).map((benefit) => (
            <div class="p-6 rounded-2xl bg-slate-50 border border-slate-100 text-center hover:border-primary/30 transition-colors">
              <span class="material-symbols-outlined text-primary text-4xl mb-4">{benefit.iconPath.includes('payments') ? 'payments' : benefit.iconPath.includes('briefcase') ? 'work_history' : benefit.iconPath.includes('sun') ? 'sunny' : 'school'}</span>
              <h4 class="font-bold text-lg mb-2 text-slate-900">{benefit.title}</h4>
              <p class="text-sm text-slate-500">{benefit.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Cities Cards -->
    <section class="py-24 px-4 bg-slate-50" id="ciudades">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold mb-12 text-slate-900">Elige tu Ciudad Ideal en {dest.name}</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {dest.cities.slice(0, 3).map((city) => (
            <div class="group relative h-[400px] rounded-3xl overflow-hidden shadow-xl cursor-pointer">
              <img 
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" 
                alt={`Estudiar en ${city.name}, ${dest.name}`}
                src={city.image}
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex flex-col justify-end p-8 text-white">
                <h3 class="text-2xl font-bold mb-2">{city.name}</h3>
                <p class="text-sm opacity-90 mb-4">{city.para}</p>
                <span class="text-xs font-bold uppercase tracking-widest text-primary">Ver Opciones</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Courses Section -->
    <section class="py-24 px-4 bg-white" id="cursos">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-bold mb-12 text-center text-slate-900">Cursos Disponibles en {dest.name}</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {courses.map((course, idx) => (
            <div class={`flex flex-col p-8 rounded-2xl border transition-colors ${course.popular ? 'border-2 border-primary bg-primary/5' : 'border-slate-200 hover:border-primary'}`}>
              <div class="flex justify-between items-start mb-4">
                <h3 class="text-xl font-extrabold text-slate-900">{course.title}</h3>
                {course.popular && (
                  <span class="bg-primary text-white text-[10px] px-2 py-1 rounded font-bold uppercase">Más Popular</span>
                )}
              </div>
              <p class="text-slate-600 mb-6 flex-grow">{course.desc}</p>
              <ul class="space-y-3 mb-8 text-sm">
                {course.features.map((feature) => (
                  <li class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary text-sm">check_circle</span>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Investment Table with Currency Converter -->
    <section class="py-24 px-4 bg-slate-50" id="costos" x-data="currencyConverter()">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-4 text-center text-slate-900">¿Cuánto Cuesta Estudiar en {dest.name}?</h2>
        <p class="text-center text-slate-500 mb-8">{dest.investmentCurrencyNote}</p>
        
        <!-- Currency Converter Controls -->
        <div class="bg-white rounded-2xl shadow-lg border border-slate-200 p-6 mb-8">
          <div class="grid md:grid-cols-2 gap-6">
            <!-- Origen: Moneda del costo -->
            <div>
              <p class="text-sm font-semibold text-slate-600 mb-3">Moneda del costo:</p>
              <button 
                @click="selectSourceCurrency('LOCAL')" 
                :class="sourceCurrency === 'LOCAL' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10 border-primary' : 'border-slate-200'"
                class="w-full flex items-center gap-3 px-4 py-3 rounded-xl border hover:bg-slate-50 transition-all"
              >
                <span class="font-medium">{dest.name} (moneda local)</span>
              </button>
            </div>
            
            <!-- Destino: Ver en esta moneda -->
            <div>
              <p class="text-sm font-semibold text-slate-600 mb-3">Ver precios en:</p>
              <div class="grid grid-cols-2 gap-2">
                <!-- Latinoamérica -->
                <button 
                  @click="selectTargetCurrency('COP')" 
                  :class="targetCurrency === 'COP' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
                  class="flex items-center gap-2 px-3 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
                >
                  <img src="https://kapowaz.github.io/circle-flags/flags/co.svg" alt="COP" class="w-4 h-4 rounded-full" />
                  <span class="text-sm font-medium">COP</span>
                </button>
                <button 
                  @click="selectTargetCurrency('MXN')" 
                  :class="targetCurrency === 'MXN' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
                  class="flex items-center gap-2 px-3 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
                >
                  <img src="https://kapowaz.github.io/circle-flags/flags/mx.svg" alt="MXN" class="w-4 h-4 rounded-full" />
                  <span class="text-sm font-medium">MXN</span>
                </button>
                <button 
                  @click="selectTargetCurrency('CLP')" 
                  :class="targetCurrency === 'CLP' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
                  class="flex items-center gap-2 px-3 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
                >
                  <img src="https://kapowaz.github.io/circle-flags/flags/cl.svg" alt="CLP" class="w-4 h-4 rounded-full" />
                  <span class="text-sm font-medium">CLP</span>
                </button>
                <button 
                  @click="selectTargetCurrency('USD')" 
                  :class="targetCurrency === 'USD' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
                  class="flex items-center gap-2 px-3 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
                >
                  <img src="https://kapowaz.github.io/circle-flags/flags/us.svg" alt="USD" class="w-4 h-4 rounded-full" />
                  <span class="text-sm font-medium">USD</span>
                </button>
                
                <!-- Destinos (para Ecuador/Panamá que quieren ver en otras monedas) -->
                <button 
                  @click="selectTargetCurrency('EUR')" 
                  :class="targetCurrency === 'EUR' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
                  class="flex items-center gap-2 px-3 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
                  x-show="sourceCurrency !== 'LOCAL' || targetCurrency === 'EUR'"
                >
                  <img src="https://kapowaz.github.io/circle-flags/flags/eu.svg" alt="EUR" class="w-4 h-4 rounded-full" />
                  <span class="text-sm font-medium">EUR</span>
                </button>
                <button 
                  @click="selectTargetCurrency('GBP')" 
                  :class="targetCurrency === 'GBP' ? 'ring-2 ring-primary ring-offset-2 bg-primary/10' : ''"
                  class="flex items-center gap-2 px-3 py-2 rounded-xl bg-slate-100 hover:bg-slate-200 transition-all"
                  x-show="sourceCurrency !== 'LOCAL' || targetCurrency === 'GBP'"
                >
                  <img src="https://kapowaz.github.io/circle-flags/flags/gb.svg" alt="GBP" class="w-4 h-4 rounded-full" />
                  <span class="text-sm font-medium">GBP</span>
                </button>
              </div>
            </div>
          </div>
          <div class="mt-3 space-y-1">
            <p class="text-xs text-center text-slate-400" x-text="getRateInfo()"></p>
            <p class="text-xs text-center text-slate-300" x-text="getLastUpdateInfo()" x-show="lastUpdated"></p>
            <div class="flex justify-center gap-2 mt-2">
              <button 
                @click="refreshRates()"
                :disabled="isLoading"
                class="text-xs text-primary hover:text-primary/80 flex items-center gap-1 disabled:opacity-50"
              >
                <span class="material-symbols-outlined text-xs" x-show="isLoading">sync</span>
                <span class="material-symbols-outlined text-xs" x-show="!isLoading">refresh</span>
                <span x-text="isLoading ? 'Actualizando...' : 'Actualizar tasas'"></span>
              </button>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-3xl overflow-hidden shadow-xl border border-slate-200">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200">
                <th class="p-6 font-bold text-slate-900">Concepto</th>
                <th class="p-6 font-bold text-right text-slate-900" 
                    x-text="sourceCurrency === 'LOCAL' && targetCurrency === 'LOCAL' ? 'Costo Estimado' : `Costo en ${currencyInfo[targetCurrency]?.name || 'tu moneda'}`">
                  Costo Estimado
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {dest.investmentRows.map((row) => (
                <tr>
                  <td class="p-6 text-slate-700">{row.concept}</td>
                  <td class="p-6 text-right font-medium text-slate-900 cost-cell">
                    <span x-text="(sourceCurrency === 'LOCAL' && targetCurrency === 'LOCAL') ? '${row.cost}' : convertCost('${row.cost}')">{row.cost}</span>
                  </td>
                </tr>
              ))}
              <tr class="bg-primary/5">
                <td class="p-6 font-bold text-primary">TOTAL ESTIMADO</td>
                <td class="p-6 text-right font-bold text-primary text-xl">
                  <span x-text="(sourceCurrency === 'LOCAL' && targetCurrency === 'LOCAL') ? '${dest.investmentTotal}' : convertCost('${dest.investmentTotal}')">{dest.investmentTotal}</span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="mt-8 text-sm text-center text-slate-400 italic">
          Los precios varían según la escuela, ciudad y duración del curso. 
          Tasas de cambio actualizadas automáticamente desde fuentes oficiales.
        </p>
      </div>

      <script is:inline>
        function currencyConverter() {
          return {
            // Moneda de origen (del costo mostrado)
            sourceCurrency: 'LOCAL',
            // Moneda de destino (lo que quiere ver el usuario)
            targetCurrency: 'COP',
            
            isLoading: true,
            lastUpdated: null,
            rateSource: 'cargando...',
            
            // Todas las tasas respecto a USD
            allRates: {
              // Destinos
              AUD: 1.56, CAD: 1.44, EUR: 0.93, GBP: 0.79, NZD: 1.72, USD: 1, AED: 3.67,
              // Latam
              COP: 3691, MXN: 20.1, CLP: 920,
            },
            
            // Info de monedas para formateo
            currencyInfo: {
              AUD: { sym: 'A$', suffix: '', name: 'Dólar Australiano' },
              CAD: { sym: 'C$', suffix: '', name: 'Dólar Canadiense' },
              EUR: { sym: '€', suffix: '', name: 'Euro' },
              GBP: { sym: '£', suffix: '', name: 'Libra' },
              NZD: { sym: 'NZ$', suffix: '', name: 'Dólar NZ' },
              USD: { sym: 'US$', suffix: '', name: 'Dólar' },
              AED: { sym: 'AED', suffix: '', name: 'Dirham' },
              COP: { sym: '$', suffix: ' COP', name: 'Peso Colombiano' },
              MXN: { sym: '$', suffix: ' MXN', name: 'Peso Mexicano' },
              CLP: { sym: '$', suffix: ' CLP', name: 'Peso Chileno' },
            },
            
            async init() {
              await this.fetchRates();
              // Set default target based on country or COP
              this.targetCurrency = 'COP';
            },
            
            async fetchRates() {
              try {
                const response = await fetch('https://open.er-api.com/v6/latest/USD');
                if (!response.ok) throw new Error('API error');
                
                const data = await response.json();
                
                if (data.result === 'success' && data.rates) {
                  // Validar y actualizar tasas
                  const validateRate = (rate, min, max) => rate >= min && rate <= max ? rate : null;
                  
                  const cop = validateRate(data.rates.COP, 3000, 5000);
                  const mxn = validateRate(data.rates.MXN, 15, 30);
                  const clp = validateRate(data.rates.CLP, 700, 1200);
                  const aud = validateRate(data.rates.AUD, 1.2, 2.0);
                  const eur = validateRate(data.rates.EUR, 0.7, 1.2);
                  const gbp = validateRate(data.rates.GBP, 0.6, 1.0);
                  
                  if (cop) this.allRates.COP = cop;
                  if (mxn) this.allRates.MXN = mxn;
                  if (clp) this.allRates.CLP = clp;
                  if (aud) this.allRates.AUD = aud;
                  if (eur) this.allRates.EUR = eur;
                  if (gbp) this.allRates.GBP = gbp;
                  
                  this.lastUpdated = new Date(data.time_last_update_utc).toLocaleString('es-ES', {
                    day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit'
                  });
                  this.rateSource = 'tiempo real';
                }
              } catch (error) {
                console.warn('[Currency] Using fallback rates:', error);
                this.rateSource = 'referencia';
                this.lastUpdated = '16 mar 2026';
              } finally {
                this.isLoading = false;
              }
            },
            
            async refreshRates() {
              this.isLoading = true;
              await this.fetchRates();
            },
            
            selectSourceCurrency(curr) {
              this.sourceCurrency = curr;
            },
            
            selectTargetCurrency(curr) {
              this.targetCurrency = curr;
            },
            
            // Detecta moneda desde string de costo
            detectCurrency(str) {
              const upper = str.toUpperCase();
              if (upper.includes('AUD')) return 'AUD';
              if (upper.includes('CAD')) return 'CAD';
              if (upper.includes('EUR') || upper.includes('€')) return 'EUR';
              if (upper.includes('GBP') || upper.includes('£')) return 'GBP';
              if (upper.includes('NZD')) return 'NZD';
              if (upper.includes('AED')) return 'AED';
              if (upper.includes('USD') || upper.includes('US$')) return 'USD';
              return 'USD';
            },
            
            // Conversión universal: cualquier moneda → cualquier moneda
            convert(amount, fromCurr, toCurr) {
              if (fromCurr === toCurr) return amount;
              if (fromCurr === 'LOCAL') {
                // El costo está en la moneda local del destino
                fromCurr = this.detectCurrency(document.querySelector('[data-dest-currency]')?.dataset.destCurrency || 'USD');
              }
              
              const fromRate = this.allRates[fromCurr];
              const toRate = this.allRates[toCurr];
              
              if (!fromRate || !toRate) return amount;
              
              // Fórmula: amount × (toRate / fromRate)
              return amount * (toRate / fromRate);
            },
            
            convertCost(str) {
              if (this.sourceCurrency === 'LOCAL' && this.targetCurrency === 'LOCAL') return str;
              
              // Extraer número
              const match = str.replace(/,/g, '').match(/[\d.]+/);
              if (!match) return str;
              
              const amount = parseFloat(match[0]);
              
              // Detectar moneda origen del string
              let fromCurr = this.detectCurrency(str);
              
              // Si sourceCurrency no es LOCAL, usar la seleccionada
              if (this.sourceCurrency !== 'LOCAL') {
                fromCurr = this.sourceCurrency;
              }
              
              const targetCurr = this.targetCurrency;
              
              // Convertir
              const converted = this.convert(amount, fromCurr, targetCurr);
              
              // Formatear
              const info = this.currencyInfo[targetCurr];
              const formatted = Math.round(converted).toLocaleString('es-ES');
              const prefix = str.toLowerCase().includes('desde') ? 'Desde ' : '';
              
              return `${prefix}${info.sym}${formatted}${info.suffix}`;
            },
            
            getRateInfo() {
              if (this.sourceCurrency === 'LOCAL' && this.targetCurrency === 'LOCAL') {
                return 'Mostrando precios en moneda local';
              }
              
              // Detectar moneda de origen actual
              let fromCurr = this.sourceCurrency;
              if (fromCurr === 'LOCAL') {
                const sampleText = document.querySelector('.cost-cell')?.textContent || '';
                fromCurr = this.detectCurrency(sampleText) || 'USD';
              }
              
              const toCurr = this.targetCurrency;
              const fromRate = this.allRates[fromCurr];
              const toRate = this.allRates[toCurr];
              
              if (!fromRate || !toRate) return '';
              
              // Calcular tasa directa
              const directRate = toRate / fromRate;
              
              let rateStr;
              if (directRate < 0.01) {
                rateStr = directRate.toExponential(2);
              } else if (directRate < 1) {
                rateStr = directRate.toFixed(4);
              } else {
                rateStr = Math.round(directRate).toLocaleString('es-ES');
              }
              
              const toInfo = this.currencyInfo[toCurr];
              const sourceInfo = this.rateSource ? ` (${this.rateSource})` : '';
              
              return `1 ${fromCurr} = ${toInfo.sym}${rateStr}${toInfo.suffix}${sourceInfo}`;
            },
            
            getLastUpdateInfo() {
              if (!this.lastUpdated) return '';
              return `Actualizado: ${this.lastUpdated}`;
            }
          }
        }
      </script>
    </section>

    <!-- FAQ Section -->
    <section class="py-24 px-4 bg-white" id="faq">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold mb-12 text-center text-slate-900">Preguntas Frecuentes sobre Estudiar en {dest.name}</h2>
        <div class="space-y-4">
          {dest.faqs.slice(0, 3).map((faq, idx) => (
            <details class="group border border-slate-200 rounded-xl bg-white p-6" open={idx === 0}>
              <summary class="flex justify-between items-center font-bold cursor-pointer list-none text-slate-900">
                {faq.q}
                <span class="material-symbols-outlined group-open:rotate-180 transition-transform">expand_more</span>
              </summary>
              <p class="mt-4 text-slate-600">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
