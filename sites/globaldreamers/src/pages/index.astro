---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import HeroHome from '../components/HeroHome.astro';
import Partners from '../components/Partners.astro';
import DestinationsHome from '../components/DestinationsHome.astro';
import DreamJourneyBuilder from '../components/DreamJourneyBuilder.astro';
import ValueProposition from '../components/ValueProposition.astro';
import ProcessSection from '../components/ProcessSection.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import FAQSection from '../components/FAQSection.astro';
import CTAFinal from '../components/CTAFinal.astro';
import Footer from '../components/Footer.astro';

const title = 'Estudiar en el Exterior 2026 | Global Dreamers - Asesoría Gratis';
const description = '✅ Asesoría 100% gratuita para estudiar en Australia, Canadá, Malta, Dubai y más. Información clara de visa y permisos según cada destino y programa. ¡Agenda tu consulta hoy!';
const keywords = [
  'estudiar en el exterior',
  'trabajar y estudiar en el exterior',
  'visa de estudiante',
  'estudiar en australia',
  'estudiar en canada',
  'estudiar en malta',
  'estudiar en dubai',
  'estudiar en reino unido',
  'estudiar en nueva zelanda',
  'estudiar en irlanda',
  'estudiar en españa',
  'estudiar en alemania',
  'estudiar en italia',
  'estudiar en estados unidos',
  'agencia de estudios en el exterior',
  'asesoría visa estudiante',
  'work and study',
];

// FAQs para Schema.org
const faqs = [
  {
    q: '¿La asesoría realmente es gratuita?',
    a: 'Sí, nuestra asesoría es 100% gratuita. No cobramos por la orientación inicial, análisis de perfil ni recomendación de destinos. Nuestro ingreso proviene de las comisiones que nos pagan las instituciones educativas cuando te inscribes a través de nosotros.'
  },
  {
    q: '¿Qué nivel de inglés necesito?',
    a: 'Depende del destino y programa. Para cursos de inglés generalmente no requieres nivel previo. Para programas vocacionales o universitarios, generalmente necesitas IELTS 5.5-6.5 o equivalente. Evaluamos tu caso particular en la asesoría gratuita.'
  },
  {
    q: '¿Puedo trabajar mientras estudio?',
    a: 'Depende del país y tipo de programa. IMPORTANTE: En Canadá y Reino Unido NO se permite trabajar si estudias solo idioma. El permiso laboral aplica únicamente para educación superior (University/College). En Australia, Irlanda, Nueva Zelanda, Malta y España sí hay permiso bajo condiciones. Te validamos la regla exacta de tu caso antes de aplicar.'
  },
  {
    q: '¿Qué pasa si rechazan mi visa?',
    a: 'Nuestra tasa de aprobación es del 99% porque preparamos meticulosamente cada aplicación. Si ocurre un rechazo, analizamos las razones, apelamos si es posible o reaplicamos con las correcciones necesarias sin costo adicional.'
  },
  {
    q: '¿Cómo calculo mi presupuesto total?',
    a: 'En la asesoría gratuita te entregamos una proyección realista por destino: matrícula, visa, seguro médico, fondos migratorios y costo de vida. Así tomas una decisión clara desde el inicio.'
  },
  {
    q: '¿Cómo es el acompañamiento durante el proceso?',
    a: 'Te acompañamos en la elección de curso, admisión institucional y preparación de visa con seguimiento constante por email y videollamada.'
  },
];

// HowTo steps
const howToSteps = [
  {
    name: 'Agenda Tu Asesoría Gratuita',
    text: 'Conversa con nuestros expertos sobre tus metas y analizamos tu perfil para recomendarte el mejor destino, ciudad y programa según tu presupuesto y objetivos.'
  },
  {
    name: 'Diseñamos Tu Plan Personalizado',
    text: 'Elegimos destino, curso y gestionamos toda tu documentación para la visa. Preparamos tu aplicación perfectamente para maximizar probabilidades de aprobación.'
  },
  {
    name: '¡Viaja y Vive Tu Sueño!',
    text: 'Te acompañamos durante la admisión y el proceso de visa, con seguimiento constante y documentación ordenada.'
  },
];
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
  schemaType={['Organization', 'WebSite', 'LocalBusiness', 'Service', 'HowTo', 'FAQPage']}
  schemaData={{
    name: 'Global Dreamers',
    description: 'Agencia internacional de educación especializada en asesorar estudiantes latinos para estudiar en Australia, Canadá, Malta, Dubai, Reino Unido, Nueva Zelanda, Irlanda, España, Alemania, Italia y Estados Unidos con información de visa según programa.',
    url: 'https://globaldreamers.com.au',
    serviceType: 'Educational Consulting',
    areaServed: [
      { '@type': 'Country', name: 'Australia' },
      { '@type': 'Country', name: 'Canada' },
      { '@type': 'Country', name: 'Malta' },
      { '@type': 'Country', name: 'United Arab Emirates' },
      { '@type': 'Country', name: 'United Kingdom' },
      { '@type': 'Country', name: 'New Zealand' },
      { '@type': 'Country', name: 'Ireland' },
      { '@type': 'Country', name: 'Spain' },
      { '@type': 'Country', name: 'Germany' },
      { '@type': 'Country', name: 'Italy' },
      { '@type': 'Country', name: 'United States' },
    ],
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Destinos de Estudio',
      itemListElement: [
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en Australia' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en Canadá' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en Malta' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en Dubai' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en Reino Unido' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en Nueva Zelanda' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en Irlanda' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en España' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en Alemania' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en Italia' } },
        { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Estudiar en Estados Unidos' } },
      ]
    },
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: '4.9',
      reviewCount: '500',
      bestRating: '5',
    },
    priceRange: '$$',
    openingHoursSpecification: {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '18:00',
    },
  }}
  howToName="Cómo empezar tu aventura de estudiar en el exterior"
  howToDescription="Guía paso a paso para comenzar tu experiencia de estudio en el exterior con Global Dreamers"
  steps={howToSteps}
  faqs={faqs}
>
  <Navbar />
  <main>
    <HeroHome />
    <Partners />
    <DestinationsHome />
    <DreamJourneyBuilder />
    <ValueProposition />
    <ProcessSection />
    <TestimonialsSection />
    <FAQSection />
    <CTAFinal />
  </main>
  <Footer />
</Layout>
