---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const certifications = [
  { name: 'Empresa Registrada en Australia', icon: 'verified' },
];

const values = [
  {
    icon: 'verified_user',
    title: 'Transparencia',
    desc: 'Procesos claros, costos honestos y comunicación abierta desde el primer día.'
  },
  {
    icon: 'volunteer_activism',
    title: 'Acompañamiento',
    desc: 'No estás solo. Te apoyamos antes, durante y después de tu llegada a tu destino.'
  },
  {
    icon: 'stars',
    title: 'Resultados',
    desc: 'Enfoque en el éxito de tu aplicación y la calidad de tu experiencia académica.'
  }
];
---

<Layout 
  title="Nosotros | Global Dreamers"
  description="Conoce al equipo de Global Dreamers. Expertos en educación internacional con oficinas en Australia. Agencia registrada legalmente ayudando a latinoamericanos a estudiar en el exterior."
  canonical="/nosotros/"
>
  <Navbar />
  
  <main class="flex-1">
    <!-- Hero Section -->
    <section class="py-12 lg:py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="flex flex-col gap-6">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-brand-100 text-brand-600 text-sm font-bold w-fit">
              <span class="material-symbols-outlined text-sm">history</span>
              Nuestra Historia
            </div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-black leading-tight text-slate-900">
              Humanizamos el camino hacia tus sueños.
            </h1>
            <p class="text-lg text-slate-600 leading-relaxed">
              Global Dreamers nació de una simple observación: el proceso de estudiar en el extranjero solía ser frío y burocrático. Decidimos cambiar eso, poniendo las aspiraciones de cada estudiante en el centro de todo lo que hacemos. No solo gestionamos trámites; construimos futuros.
            </p>
            <div class="flex items-center gap-4 pt-4">
              <div class="flex items-center gap-2 px-4 py-2 bg-green-50 text-green-700 rounded-lg">
                <span class="text-lg">🇦🇺</span>
                <span class="text-sm font-semibold">Empresa Australiana</span>
              </div>
              <div class="flex items-center gap-2 px-4 py-2 bg-brand-50 text-brand-600 rounded-lg">
                <span class="material-symbols-outlined text-sm">verified</span>
                <span class="text-sm font-semibold">15+ años de experiencia</span>
              </div>
            </div>
          </div>
          <div class="relative">
            <div class="rounded-3xl overflow-hidden shadow-2xl">
              <img 
                src="/images/hero-students.png" 
                alt="Equipo Global Dreamers con estudiantes internacionales"
                class="w-full h-auto object-cover"
              />
            </div>
            <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl border border-slate-100">
              <div class="flex items-center gap-4">
                <div class="bg-brand-100 p-3 rounded-full">
                  <span class="material-symbols-outlined text-brand-600 text-2xl">groups</span>
                </div>
                <div>
                  <p class="text-3xl font-bold text-slate-900">+5,000</p>
                  <p class="text-sm text-slate-500">Sueños cumplidos</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission & Vision -->
    <section class="py-16 bg-slate-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-slate-900 mb-4">Propósito y Futuro</h2>
          <div class="w-20 h-1 bg-brand-600 mx-auto rounded-full"></div>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Mission -->
          <div class="flex flex-col gap-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm hover:shadow-lg transition-shadow">
            <div class="bg-brand-100 w-14 h-14 flex items-center justify-center rounded-xl">
              <span class="material-symbols-outlined text-brand-600 text-3xl">target</span>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-slate-900 mb-3">Nuestra Misión</h3>
              <p class="text-slate-600 leading-relaxed">
                Empoderar a los estudiantes para que alcancen su máximo potencial académico y personal a través de experiencias de educación internacional transformadoras, guiándolos con empatía y experiencia en cada paso.
              </p>
            </div>
          </div>
          <!-- Vision -->
          <div class="flex flex-col gap-6 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm hover:shadow-lg transition-shadow">
            <div class="bg-brand-100 w-14 h-14 flex items-center justify-center rounded-xl">
              <span class="material-symbols-outlined text-brand-600 text-3xl">visibility</span>
            </div>
            <div>
              <h3 class="text-2xl font-bold text-slate-900 mb-3">Nuestra Visión</h3>
              <p class="text-slate-600 leading-relaxed">
                Ser la agencia líder mundial reconocida por su calidez humana y excelencia técnica, convirtiéndonos en el puente preferido para los soñadores que buscan expandir sus horizontes educativos.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="text-3xl font-bold text-slate-900 mb-4">Nuestros Valores</h2>
          <p class="text-slate-500 max-w-2xl mx-auto">Lo que nos guía en cada asesoría y cada decisión que tomamos para tu futuro.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-10">
          {values.map((value) => (
            <div class="text-center group">
              <div class="mb-6 mx-auto w-16 h-16 flex items-center justify-center rounded-full bg-slate-100 group-hover:bg-brand-600 group-hover:text-white transition-all">
                <span class="material-symbols-outlined text-3xl">{value.icon}</span>
              </div>
              <h4 class="text-xl font-bold text-slate-900 mb-2">{value.title}</h4>
              <p class="text-slate-600">{value.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Certifications -->
    <section class="py-16 border-b border-slate-200 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-center text-slate-500 text-sm font-bold uppercase tracking-widest mb-10">
          Respaldados por las mejores instituciones
        </p>
        <div class="flex flex-wrap justify-center items-center gap-12 md:gap-20">
          {certifications.map((cert) => (
            <div class="flex items-center gap-2 text-slate-400 hover:text-slate-600 transition-colors">
              <span class="material-symbols-outlined text-4xl">{cert.icon}</span>
              <span class="font-bold text-lg uppercase">{cert.name}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <div class="relative bg-brand-600 rounded-[2rem] overflow-hidden px-8 py-16 text-center text-white">
        <!-- Decorative elements -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full -mr-32 -mt-32"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-black/10 rounded-full -ml-24 -mb-24"></div>
        <div class="relative z-10 max-w-2xl mx-auto">
          <h2 class="text-3xl md:text-5xl font-black mb-6">¿Listo para dar el primer paso?</h2>
          <p class="text-lg text-brand-100 mb-10 opacity-90">
            Tu futuro no tiene fronteras. Agenda una sesión gratuita y descubre cómo podemos ayudarte a estudiar donde siempre has soñado.
          </p>
          <a 
            href="/#contacto"
            class="inline-flex items-center gap-2 bg-white text-brand-600 px-8 py-4 rounded-xl text-lg font-bold hover:bg-slate-100 transition-colors shadow-xl"
          >
            Conoce a tu futuro asesor
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
