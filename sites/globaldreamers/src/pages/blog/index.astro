---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('blog', ({ data }) => {
  return data.published !== false;
});

// Sort by date descending
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by category
const postsByCategory = sortedPosts.reduce((acc, post) => {
  const category = post.data.category;
  if (!acc[category]) acc[category] = [];
  acc[category].push(post);
  return acc;
}, {});

const categories = Object.keys(postsByCategory);

// Schema for Blog page
const schemaBlog = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog Global Dreamers",
  "description": "Guías, consejos y recursos para estudiar en el exterior. Descubre todo lo que necesitas saber para cumplir tu sueño de estudiar en el extranjero.",
  "url": "https://globaldreamers.com.au/blog/",
  "publisher": {
    "@type": "Organization",
    "name": "Global Dreamers",
    "logo": {
      "@type": "ImageObject",
      "url": "https://globaldreamers.com.au/images/logo.png"
    }
  }
};
---

<Layout 
  title="Blog | Global Dreamers"
  description="Guías, consejos y recursos para estudiar en el exterior. Descubre todo sobre destinos, visas, becas y más para cumplir tu sueño de estudiar en el extranjero."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schemaBlog)} />
  
  <!-- Hero -->
  <section class="bg-gradient-to-br from-brand-50 via-white to-brand-50 py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-full shadow-sm border border-brand-100 mb-6">
        <span class="material-symbols-outlined text-brand-600">article</span>
        <span class="text-sm font-medium text-slate-700">Blog de Estudios en el Exterior</span>
      </div>
      
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6" style="font-family: 'Inter', system-ui, sans-serif;">
        Todo lo que necesitas saber para<br />
        <span class="text-gradient">estudiar en el exterior</span>
      </h1>
      
      <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-8">
        Guías completas, consejos prácticos y experiencias reales para ayudarte a cumplir 
        tu sueño de estudiar en el extranjero. Desde requisitos hasta testimonios.
      </p>

      <!-- Stats -->
      <div class="flex flex-wrap items-center justify-center gap-8 text-sm">
        <div class="flex items-center gap-2 text-slate-600">
          <span class="material-symbols-outlined text-brand-600">article</span>
          <span><strong>{sortedPosts.length}</strong> artículos publicados</span>
        </div>
        <div class="flex items-center gap-2 text-slate-600">
          <span class="material-symbols-outlined text-brand-600">folder</span>
          <span><strong>{categories.length}</strong> categorías</span>
        </div>
        <div class="flex items-center gap-2 text-slate-600">
          <span class="material-symbols-outlined text-brand-600">update</span>
          <span>Actualizado regularmente</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Filter -->
  {categories.length > 0 && (
    <section class="bg-white border-b border-slate-100 py-6 sticky top-0 z-30">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-4 overflow-x-auto pb-2 scrollbar-hide">
          <span class="text-sm font-medium text-slate-500 flex-shrink-0">Filtrar por:</span>
          <button class="px-4 py-2 bg-brand-600 text-white text-sm font-medium rounded-full whitespace-nowrap">
            Todos
          </button>
          {categories.map(category => (
            <a 
              href={`#${category.toLowerCase().replace(/\s+/g, '-')}`}
              class="px-4 py-2 bg-slate-100 text-slate-700 text-sm font-medium rounded-full whitespace-nowrap hover:bg-brand-100 hover:text-brand-700 transition-colors"
            >
              {category}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Blog Posts -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      {sortedPosts.length === 0 ? (
        <div class="text-center py-16">
          <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="material-symbols-outlined text-4xl text-slate-400">article</span>
          </div>
          <h2 class="text-xl font-bold text-slate-900 mb-2" style="font-family: 'Inter', system-ui, sans-serif;">
            Próximamente
          </h2>
          <p class="text-slate-600">
            Estamos preparando contenido valioso para ti. ¡Vuelve pronto!
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map(post => {
            const wordCount = post.body?.split(/\s+/).length || 0;
            const readingTime = Math.ceil(wordCount / 200);
            
            return (
              <article class="group bg-white rounded-2xl border border-slate-100 overflow-hidden hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-300">
                <a href={`/blog/${post.slug}/`} class="block">
                  <!-- Image -->
                  <div class="relative h-48 overflow-hidden">
                    {post.data.image ? (
                      <img 
                        src={post.data.image} 
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full bg-gradient-to-br from-brand-100 to-brand-50 flex items-center justify-center">
                        <span class="material-symbols-outlined text-6xl text-brand-300">article</span>
                      </div>
                    )}
                    <div class="absolute top-4 left-4">
                      <span class="px-3 py-1 bg-white/90 backdrop-blur-sm text-brand-700 text-xs font-semibold rounded-full">
                        {post.data.category}
                      </span>
                    </div>
                  </div>
                  
                  <!-- Content -->
                  <div class="p-6">
                    <h2 class="font-display text-lg font-bold text-slate-900 mb-3 line-clamp-2 group-hover:text-brand-600 transition-colors">
                      {post.data.title}
                    </h2>
                    <p class="text-slate-600 text-sm mb-4 line-clamp-3">
                      {post.data.excerpt}
                    </p>
                    
                    <!-- Meta -->
                    <div class="flex items-center justify-between text-xs text-slate-500">
                      <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">schedule</span>
                        <span>{readingTime} min</span>
                      </div>
                      <time datetime={post.data.date.toISOString()}>
                        {post.data.date.toLocaleDateString('es-ES', { 
                          month: 'short', 
                          day: 'numeric' 
                        })}
                      </time>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="bg-slate-50 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="w-16 h-16 bg-brand-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <span class="material-symbols-outlined text-3xl text-brand-600">mail</span>
      </div>
      <h2 class="text-2xl font-bold text-slate-900 mb-4" style="font-family: 'Inter', system-ui, sans-serif;">
        Recibe las mejores guías en tu email
      </h2>
      <p class="text-slate-600 mb-8 max-w-lg mx-auto">
        Suscríbete y recibe contenido exclusivo sobre estudios en el exterior, 
        becas, visas y experiencias de estudiantes.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 max-w-md mx-auto">
        <input 
          type="email" 
          placeholder="Tu correo electrónico"
          class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-200"
        />
        <button class="w-full sm:w-auto px-6 py-3 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors whitespace-nowrap">
          Suscribirme
        </button>
      </div>
      <p class="text-xs text-slate-500 mt-4">
        Sin spam. Puedes darte de baja en cualquier momento.
      </p>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4" style="font-family: 'Inter', system-ui, sans-serif;">
        ¿Listo para empezar tu aventura?
      </h2>
      <p class="text-slate-600 mb-8 max-w-2xl mx-auto">
        Agenda una asesoría gratuita con nuestros expertos. Te ayudamos a planificar 
        tu estudio en el exterior paso a paso.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href="/asesoria-gratuita/"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-brand-600 text-white font-semibold rounded-xl hover:bg-brand-700 transition-colors shadow-lg shadow-brand-600/25"
        >
          <span class="material-symbols-outlined">calendar_today</span>
          Agendar asesoría gratis
        </a>
        <a 
          href="https://wa.me/61449159849?text=Hola%20Global%20Dreamers%2C%20vi%20el%20blog%20y%20quiero%20m%C3%A1s%20informaci%C3%B3n"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-slate-700 font-semibold rounded-xl border-2 border-slate-200 hover:border-brand-600 hover:text-brand-600 transition-colors"
        >
          <span class="material-symbols-outlined">chat</span>
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
