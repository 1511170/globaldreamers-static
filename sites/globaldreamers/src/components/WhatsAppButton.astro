---
/**
 * WhatsAppButton - Componente reutilizable con tracking completo
 * 
 * Props:
 * - variant: 'hero' | 'cta' | 'service' | 'blog' | 'destination' | 'card' | 'footer' | 'testimonial'
 * - location: Identificador único de ubicación (ej: 'hero-home', 'cta-australia')
 * - message: Mensaje base del usuario
 * - destinationCountry: País de destino (opcional)
 * - pageType: Tipo de página (opcional, se detecta automáticamente)
 * - className: Clases CSS adicionales
 * - showIcon: Mostrar ícono de WhatsApp (default: true)
 * - iconPosition: 'left' | 'right' (default: 'left')
 * - buttonText: Texto del botón (si no se proporciona, usa slot)
 * - size: 'sm' | 'md' | 'lg' (default: 'md')
 * - style: 'primary' | 'secondary' | 'outline' (default: 'primary')
 */

interface Props {
  variant: 'hero' | 'cta' | 'service' | 'blog' | 'destination' | 'card' | 'footer' | 'testimonial';
  location: string;
  message: string;
  destinationCountry?: string;
  pageType?: string;
  className?: string;
  showIcon?: boolean;
  iconPosition?: 'left' | 'right';
  buttonText?: string;
  size?: 'sm' | 'md' | 'lg';
  style?: 'primary' | 'secondary' | 'outline';
}

const {
  variant,
  location,
  message,
  destinationCountry = '',
  pageType = '',
  className = '',
  showIcon = true,
  iconPosition = 'left',
  buttonText = '',
  size = 'md',
  style = 'primary'
} = Astro.props;

const WHATSAPP_NUMBER = '61449159849';

// Generar ID único para el botón
const buttonId = `wa-btn-${variant}-${location.replace(/\s+/g, '-').toLowerCase()}-${Math.random().toString(36).substr(2, 9)}`;

// Clases CSS según tamaño
const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg'
};

// Clases CSS según estilo
const styleClasses = {
  primary: 'bg-[#25D366] hover:bg-[#128C7E] text-white shadow-lg hover:shadow-xl',
  secondary: 'bg-brand-600 hover:bg-brand-700 text-white shadow-lg hover:shadow-xl',
  outline: 'bg-white border-2 border-[#25D366] text-[#25D366] hover:bg-[#25D366] hover:text-white'
};

const baseClasses = `inline-flex items-center justify-center gap-2 rounded-full font-semibold transition-all duration-300 hover:scale-105 ${sizeClasses[size]} ${styleClasses[style]} ${className}`;
---

<a
  id={buttonId}
  href="#"
  target="_blank"
  rel="noopener noreferrer"
  class={baseClasses}
  data-variant={variant}
  data-location={location}
  data-destination={destinationCountry}
  data-page-type={pageType}
  data-base-message={message}
>
  {showIcon && iconPosition === 'left' && (
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.57h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  )}
  
  {buttonText ? <span>{buttonText}</span> : <slot />}
  
  {showIcon && iconPosition === 'right' && (
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.57h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  )}
</a>

<script is:inline define:vars={{ buttonId, WHATSAPP_NUMBER }}>
  (function() {
    const btn = document.getElementById(buttonId);
    if (!btn) return;

    // Obtener datos del botón
    const variant = btn.dataset.variant || 'unknown';
    const location = btn.dataset.location || 'unknown';
    const destinationCountry = btn.dataset.destination || 'general';
    const pageType = btn.dataset.pageType || document.body.dataset.pageType || 'unknown';
    const baseMessage = btn.dataset.baseMessage || 'Hola, me interesa recibir información';
    
    // Obtener info de página
    const currentUrl = window.location.href;
    const pageTitle = document.title;
    const cleanUrl = currentUrl.split('?')[0];
    
    // Generar mensaje completo
    const fullMessage = `${baseMessage}\n\n📄 Página: ${pageTitle}\n🔗 URL: ${cleanUrl}\n\n(Vía: ${variant})`;
    const encodedMessage = encodeURIComponent(fullMessage);
    
    // Actualizar href
    btn.href = `https://wa.me/${WHATSAPP_NUMBER}?text=${encodedMessage}`;
    
    // Función de tracking
    function trackClick() {
      const trackingData = {
        button_variant: variant,
        button_location: location,
        page_url: currentUrl,
        page_title: pageTitle,
        page_type: pageType,
        destination_country: destinationCountry,
        section: location,
        transport_type: 'beacon'
      };

      // GA4
      if (typeof gtag !== 'undefined') {
        gtag('event', 'whatsapp_click', trackingData);
        gtag('event', `whatsapp_${variant}_click`, { page_url: currentUrl, page_title: pageTitle });
        gtag('event', 'generate_lead', {
          value: 1.0,
          currency: 'USD',
          lead_source: 'whatsapp',
          lead_medium: variant,
          page_location: currentUrl
        });
      }

      // dataLayer
      if (typeof dataLayer !== 'undefined') {
        dataLayer.push({
          event: 'whatsapp_click',
          ...trackingData,
          event_timestamp: new Date().toISOString()
        });
      }

      console.log('[WhatsApp Button] Click:', { variant, location, destinationCountry });
    }

    btn.addEventListener('click', trackClick);
  })();
</script>
