---
---

<section class="relative min-h-screen bg-gray-50 overflow-hidden flex items-center pt-16">
  <!-- Gradient Orbs Animados (Fondo premium) -->
  <div class="gradient-orb orb-1"></div>
  <div class="gradient-orb orb-2" style="width: 400px; height: 400px; background: linear-gradient(135deg, #22d3ee, #0ea5e9); top: 40%; left: -5%;"></div>
  
  <!-- Grid Pattern Overlay sutil -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23000000\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-8 py-20 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <!-- Left column -->
    <div class="flex flex-col gap-8">
      <!-- Badge con animación -->
      <div class="hero-badge animate-fade-up inline-flex items-center gap-2 px-5 py-2 bg-brand-100 rounded-full w-fit hover-glow cursor-default">
        <svg class="w-4 h-4 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
        </svg>
        <span class="text-brand-600 text-sm font-semibold">Agencia Certificada Internacionalmente</span>
      </div>

      <!-- Headline con animación -->
      <div class="hero-title-animate flex flex-col gap-3">
        <h1 class="font-display font-extrabold text-6xl leading-tight text-gray-900">
          Estudia, Trabaja y<br />Vive en el <span class="text-gradient">Exterior</span>
        </h1>
        <p class="hero-subtitle-animate font-display font-medium text-2xl text-gray-500">
          Hacemos Tu Sueño Realidad
        </p>
      </div>

      <!-- Body con animación -->
      <p class="hero-subtitle-animate text-lg text-gray-500 leading-relaxed max-w-lg">
        Te acompañamos en cada paso de tu aventura internacional.
        Asesoría personalizada, visas aprobadas y soporte en destino.
      </p>

      <!-- CTA Buttons con efectos premium -->
      <div class="hero-cta-animate flex flex-wrap gap-4">
        <a
          href="https://wa.me/61449159849?text=Hola%2C%20quiero%20agendar%20mi%20asesor%C3%ADa%20gratuita"
          target="_blank"
          rel="noopener noreferrer"
          class="magnetic-button shine btn-arrow group relative inline-flex items-center gap-3 px-7 py-4 bg-brand-600 text-white font-bold rounded-full hover:bg-brand-500 transition-all duration-300 shadow-lg hover:shadow-xl shadow-brand-600/30 transform hover:-translate-y-1"
        >
          <span>Agenda Tu Asesoría<br /><span class="font-extrabold">GRATIS</span></span>
          <svg class="arrow-icon w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a
          href="#testimonios"
          class="hover-lift inline-flex items-center gap-3 px-7 py-4 bg-white text-gray-700 font-bold rounded-full border border-gray-200 hover:border-brand-300 hover:text-brand-600 transition-all duration-300 shadow-md hover:shadow-lg"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Ver<br />Testimonios</span>
        </a>
      </div>

      <!-- Social proof con animación -->
      <div class="animate-fade-up delay-300 flex items-center gap-6">
        <!-- Avatars -->
        <div class="flex items-center">
          <img src="/images/avatar-1.png" alt="Estudiante" class="w-10 h-10 rounded-full border-2 border-white object-cover hover-scale cursor-pointer" />
          <img src="/images/avatar-2.png" alt="Estudiante" class="w-10 h-10 rounded-full border-2 border-white object-cover -ml-3 hover-scale cursor-pointer" />
          <img src="/images/avatar-3.png" alt="Estudiante" class="w-10 h-10 rounded-full border-2 border-white object-cover -ml-3 hover-scale cursor-pointer" />
          <div class="w-10 h-10 rounded-full border-2 border-white bg-gray-50 -ml-3 flex items-center justify-center hover-scale cursor-pointer">
            <span class="text-xs font-bold text-gray-600">+500</span>
          </div>
        </div>
        <!-- Rating -->
        <div class="flex flex-col gap-0.5">
          <div class="flex items-center gap-1.5">
            <div class="flex text-yellow-400">
              {Array(5).fill(0).map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="font-bold text-gray-900 text-sm">4.9/5</span>
          </div>
          <span class="text-sm text-gray-500">Estudiantes satisfechos</span>
        </div>
      </div>
    </div>

    <!-- Right column — Hero image + floating cards -->
    <div class="relative">
      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-tr from-brand-600 to-sky-500 rounded-3xl opacity-20 pointer-events-none"></div>

      <!-- Hero image con reveal animation -->
      <div class="image-reveal relative rounded-3xl overflow-hidden shadow-2xl border-4 border-white">
        <img
          src="/images/hero.png"
          alt="Estudiantes en el exterior"
          class="w-full h-[480px] object-cover"
        />
      </div>

      <!-- Floating card: Tasa de Aprobación (con animación flotante mejorada) -->
      <div class="animate-float glass-card absolute -left-8 top-1/2 -translate-y-1/2 rounded-2xl shadow-xl p-4 flex items-center gap-3 z-10 hover-lift cursor-default">
        <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-gray-500 font-medium">Tasa de Aprobación</p>
          <p class="text-lg font-bold text-gray-900"><span class="counter-value" data-value="99">0</span>% en Visas</p>
        </div>
      </div>

      <!-- Floating card: Viaja Seguro (con animación flotante delayed) -->
      <div class="animate-float-delayed glass-card absolute -right-6 bottom-8 rounded-2xl shadow-xl p-4 flex items-center gap-3 z-10 hover-lift cursor-default">
        <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
          </svg>
        </div>
        <div>
          <p class="text-lg font-bold text-gray-900">Viaja Seguro</p>
          <p class="text-xs text-gray-500">+15k estudiantes</p>
        </div>
      </div>
      
      <!-- Floating badge: Destinos -->
      <div class="glass-card absolute -top-4 right-12 rounded-xl shadow-lg p-3 flex items-center gap-2 z-10 animate-float hover-scale cursor-default" style="animation-delay: 1s;">
        <div class="flex -space-x-2">
          <img src="https://kapowaz.github.io/circle-flags/flags/au.svg" class="w-6 h-6 rounded-full border border-white" alt="AU" />
          <img src="https://kapowaz.github.io/circle-flags/flags/ca.svg" class="w-6 h-6 rounded-full border border-white" alt="CA" />
          <img src="https://kapowaz.github.io/circle-flags/flags/gb.svg" class="w-6 h-6 rounded-full border border-white" alt="GB" />
        </div>
        <span class="text-xs font-bold text-gray-700">+50 Destinos</span>
      </div>
    </div>
  </div>
  
  <!-- Bottom wave SVG -->
  <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
      <path d="M0 120L60 110C120 100 240 80 360 70C480 60 600 60 720 65C840 70 960 80 1080 85C1200 90 1320 90 1380 90L1440 90V120H1380C1320 120 1200 120 1080 120C960 120 840 120 720 120C600 120 480 120 360 120C240 120 120 120 60 120H0Z" fill="white"/>
    </svg>
  </div>
</section>
