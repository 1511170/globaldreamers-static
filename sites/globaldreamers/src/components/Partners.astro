---
const partners = [
  { name: 'Greenwich English College', logo: '/images/partners/logo-greenwich.png', width: 160 },
  { name: 'Hawthorn English', logo: '/images/partners/logo-hawthorn.svg', width: 140 },
  { name: 'Discover English', logo: '/images/partners/logo-discover.png', width: 150 },
  { name: 'ILSC', logo: '/images/partners/logo-ilsc.svg', width: 100 },
  { name: 'ELSIS', logo: '/images/partners/logo-elsis.png', width: 120 },
  { name: 'ECA College', logo: '/images/partners/logo-eca.png', width: 130 },
  { name: 'IKON Institute of Australia', logo: '/images/partners/logo-ikon.png', width: 150 },
  { name: 'ALG', logo: '/images/partners/logo-alg.svg', width: 120 },
  { name: 'Insight Academy', logo: '/images/partners/logo-insight.png', width: 160 },
  { name: 'English Path', logo: '/images/partners/logo-englishpath.png', width: 150 },
  { name: 'Atlas Language School', logo: '/images/partners/logo-atlas.png', width: 140 },
];

const stats = [
  { value: '99%',  label: 'Visas Aprobadas' },
  { value: '15+',  label: 'años de experiencia' },
  { value: '11',   label: 'Destinos Globales' },
  { value: '24/7', label: 'Soporte en Destino' },
];
---

<section class="bg-white border border-gray-100">
  <div class="max-w-7xl mx-auto px-8 py-12 flex flex-col gap-8">
    <!-- Título -->
    <p class="text-center text-sm font-semibold text-gray-400 uppercase tracking-widest">
      Trabajamos con las mejores instituciones
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {partners.map((partner) => (
        <div class="flex items-center justify-center rounded-xl border border-gray-200 bg-slate-50 px-6 py-6 text-center hover:shadow-sm transition-shadow">
          <img
            src={partner.logo}
            alt={partner.name}
            class="h-12 w-auto object-contain max-w-full"
            loading="lazy"
            style={`max-width: ${partner.width}px;`}
          />
        </div>
      ))}
    </div>

    <!-- Certificación ICEF -->
    <div class="flex justify-center pt-4 border-t border-gray-100">
      <div class="flex items-center gap-4 bg-slate-50 px-6 py-4 rounded-xl">
        <a href="https://www.icef.com/agency/0016M00002eumjPQAQ" target="_blank" rel="noopener noreferrer">
          <img
            src="/images/certification-icef.png"
            alt="ICEF Accredited Agency #5642"
            class="h-16 w-auto"
            loading="lazy"
          />
        </a>
        <div class="text-left">
          <p class="text-sm font-bold text-slate-900">ICEF Accredited Agency</p>
          <p class="text-xs text-slate-500">Agencia Certificada #5642</p>
          <p class="text-xs text-slate-400">Trusted International Education Agency</p>
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="border-t border-gray-100 pt-8 grid grid-cols-2 md:grid-cols-4 gap-6">
      {stats.map(stat => (
        <div class="flex flex-col items-center gap-1">
          <span class="font-sans font-extrabold text-4xl text-brand-600">{stat.value}</span>
          <span class="text-sm font-medium text-gray-500 text-center">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
