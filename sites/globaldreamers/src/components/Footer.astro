---
import { destinations } from '../data/destinations';

// Destinos principales (primeros 6)
const mainDestinations = destinations.slice(0, 6).map(d => ({
  label: `${d.name}`,
  href: d.canonical
}));

// Navegación de la compañía
const companyLinks = [
  { label: 'Sobre Nosotros', href: '/nosotros' },
  { label: 'Nuestros Servicios', href: '/servicios' },
  { label: 'Cómo Funciona', href: '/#proceso' },
  { label: 'Testimonios', href: '/#testimonios' },
  { label: 'Blog', href: '/blog' },
  { label: 'FAQ', href: '/#faq' },
];

// Recursos
const resourceLinks = [
  { label: 'Guía de Visas', href: '#' },
  { label: 'Calculadora de Costos', href: '#' },
  { label: 'Blog', href: '/blog' },
  { label: 'Preguntas Frecuentes', href: '/#faq' },
];

// Contacto - Datos de Australia
const WHATSAPP_NUMBER = '61449159849';
const contactInfo = {
  email: 'info@globaldreamers.com.au',
  phone: '+61 449 159 849',
  address: 'Melbourne, Victoria, Australia',
  whatsapp: `https://wa.me/${WHATSAPP_NUMBER}?text=Hola%2C%20me%20interesa%20recibir%20asesor%C3%ADa%20para%20estudiar%20en%20el%20exterior`,
  abn: '73384896450', // Australian Business Number
};

const socialLinks = [
  { label: 'Facebook', href: 'https://www.facebook.com/profile.php?id=100092555559597&mibextid=ZbWKwL', icon: 'facebook' },
  { label: 'Instagram', href: 'https://www.instagram.com/globaldreamers_col/', icon: 'instagram' },
  { label: 'TikTok', href: 'https://www.tiktok.com/@global.dreamers', icon: 'tiktok' },
];
---

<footer id="contacto" class="bg-slate-900 text-slate-400">
  {/* Main Footer */}
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12">
      
      {/* Brand Column */}
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center mb-6">
          <img 
            src="/images/logo-globaldreamers-white.png" 
            alt="Global Dreamers"
            class="h-12 w-auto"
          />
        </a>
        
        {/* Badge de empresa australiana */}
        <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-blue-600/20 border border-blue-500/30 rounded-lg mb-4">
          <span class="text-lg">🇦🇺</span>
          <span class="text-xs font-semibold text-blue-300">Empresa Registrada en Australia</span>
        </div>
        
        <p class="text-sm leading-relaxed mb-4 max-w-sm">
          Conectamos sueños con oportunidades globales. Agencia líder en educación internacional 
          con más de 500 estudiantes felices viviendo su experiencia en el exterior.
        </p>
        
        {/* Certificaciones */}
        <div class="flex flex-wrap items-center gap-4 mb-6">
          <img 
            src="/images/certification-icef.png" 
            alt="ICEF Accredited Agency #5642"
            class="h-14 w-auto"
          />
          <img 
            src="/images/certification-pier.png" 
            alt="PIER Qualified"
            class="h-10 w-auto"
          />
        </div>
        
        {/* Info legal */}
        <div class="text-xs text-slate-500 mb-6">
          <p class="text-slate-400">Global Dreamers</p>
          <p><span class="text-slate-400">ABN:</span> {contactInfo.abn}</p>
        </div>
        
        {/* Social / Contact Quick Links */}
        <div class="flex items-center gap-4">
          <a 
            href={contactInfo.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 px-4 py-2 bg-[#25D366] text-white text-sm font-semibold rounded-lg hover:bg-[#128C7E] transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.57h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
          <a 
            href={`mailto:${contactInfo.email}`}
            class="flex items-center justify-center w-10 h-10 bg-slate-800 text-slate-400 rounded-lg hover:bg-slate-700 hover:text-white transition-colors"
          >
            <span class="material-symbols-outlined text-lg">mail</span>
          </a>
        </div>

        <div class="flex items-center gap-3 mt-4">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="flex items-center justify-center w-10 h-10 bg-slate-800 text-slate-400 rounded-lg hover:bg-slate-700 hover:text-white transition-colors"
            >
              <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                {social.icon === 'facebook' && <path d="M22 12a10 10 0 10-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.77-3.89 1.09 0 2.24.2 2.24.2v2.46H15.2c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0022 12z" />}
                {social.icon === 'instagram' && <path d="M7.75 2h8.5A5.75 5.75 0 0122 7.75v8.5A5.75 5.75 0 0116.25 22h-8.5A5.75 5.75 0 012 16.25v-8.5A5.75 5.75 0 017.75 2zm0 1.8A3.95 3.95 0 003.8 7.75v8.5a3.95 3.95 0 003.95 3.95h8.5a3.95 3.95 0 003.95-3.95v-8.5a3.95 3.95 0 00-3.95-3.95h-8.5zm8.85 1.35a1.1 1.1 0 110 2.2 1.1 1.1 0 010-2.2zM12 7a5 5 0 110 10 5 5 0 010-10zm0 1.8a3.2 3.2 0 100 6.4 3.2 3.2 0 000-6.4z" />}
                {social.icon === 'tiktok' && <path d="M14.5 3c.3 1.4 1.1 2.5 2.4 3.2.8.4 1.7.6 2.6.6v2.5c-1 0-2-.2-2.9-.6v5.2A5.9 5.9 0 1110.6 8h.3v2.6h-.3a3.3 3.3 0 103.3 3.3V3h2.6z" />}
              </svg>
            </a>
          ))}
        </div>
      </div>

      {/* Destinos Column */}
      <div>
        <h4 class="text-white font-bold mb-6">Destinos</h4>
        <ul class="space-y-3 text-sm">
          {mainDestinations.map((d) => (
            <li>
              <a class="hover:text-primary transition-colors flex items-center gap-2" href={d.href}>
                {d.label}
              </a>
            </li>
          ))}
        </ul>
        <a href="/destinos" class="inline-block mt-4 text-sm font-semibold text-primary hover:text-primary/80 transition-colors">
          Ver todos →
        </a>
      </div>

      {/* Compañía Column */}
      <div>
        <h4 class="text-white font-bold mb-6">Compañía</h4>
        <ul class="space-y-3 text-sm">
          {companyLinks.map((link) => (
            <li>
              <a class="hover:text-primary transition-colors" href={link.href}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Contacto Column */}
      <div>
        <h4 class="text-white font-bold mb-6 flex items-center gap-2">
          <span class="text-lg">🇦🇺</span>
          Contacto Australia
        </h4>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg">mail</span>
            <a href={`mailto:${contactInfo.email}`} class="hover:text-primary transition-colors">
              {contactInfo.email}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg">phone</span>
            <a href={`tel:${contactInfo.phone.replace(/\s/g, '')}`} class="hover:text-primary transition-colors">
              {contactInfo.phone}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg mt-0.5">location_on</span>
            <span>{contactInfo.address}</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="material-symbols-outlined text-primary text-lg">schedule</span>
            <span class="text-xs">
              <span class="text-white font-medium">Horario:</span><br/>
              Lun - Vie: 9:00 - 18:00 AEST
            </span>
          </li>
        </ul>

        {/* Recursos en la misma columna */}
        <h4 class="text-white font-bold mb-4 mt-8">Recursos</h4>
        <ul class="space-y-3 text-sm">
          {resourceLinks.map((link) => (
            <li>
              <a class="hover:text-primary transition-colors" href={link.href}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  {/* Bottom Bar */}
  <div class="border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-4 text-xs text-slate-500">
          <p>© {new Date().getFullYear()} Global Dreamers Pty Ltd. Todos los derechos reservados.</p>
          <span class="hidden sm:inline">|</span>
          <div class="flex items-center gap-2">
            <span class="text-lg">🇦🇺</span>
            <span>Empresa registrada en Australia</span>
          </div>
        </div>
        <div class="flex flex-wrap justify-center gap-6 text-xs">
          <a class="text-slate-500 hover:text-white transition-colors" href="#">Política de Privacidad</a>
          <a class="text-slate-500 hover:text-white transition-colors" href="#">Términos y Condiciones</a>
          <a class="text-slate-500 hover:text-white transition-colors" href="#">Cookies</a>
        </div>
      </div>
    </div>
  </div>
</footer>
