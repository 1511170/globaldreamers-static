---
import { testimonials } from '../data/testimonials';

// Mostrar todos los testimonios disponibles
const allTestimonials = testimonials;
---

<section class="py-20 overflow-hidden bg-slate-50" id="testimonios">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center mb-4 text-slate-900">Historias Reales de Nuestros Dreamers</h2>
    <p class="text-center text-slate-600 mb-12 max-w-2xl mx-auto">
      Cada día más estudiantes cumplen su sueño de estudiar en el exterior.
      Estas son las experiencias de quienes confiaron en nosotros.
    </p>

    <!-- Grid principal de testimonios -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {allTestimonials.map((t) => (
        <div class="bg-white p-8 rounded-2xl shadow-lg border border-slate-100 hover:shadow-xl transition-shadow">
          <div class="flex gap-1 text-yellow-400 mb-4">
            {[1,2,3,4,5].map(() => (
              <span class="material-symbols-outlined fill-1 text-xl">star</span>
            ))}
          </div>
          <p class="italic text-slate-600 mb-6 line-clamp-4">"{t.quote}"</p>
          <div class="flex items-center gap-4">
            <img
              class="size-20 rounded-2xl object-cover shadow-md"
              src={t.image}
              alt={t.name}
              loading="lazy"
              width="80"
              height="80"
            />
            <div>
              <p class="font-bold text-slate-900">{t.name}</p>
              <p class="text-xs text-slate-500 uppercase">{t.role}</p>
            </div>
          </div>
        </div>
      ))}

      <!-- Call to Action - Dejar Testimonio -->
      <div class="bg-gradient-to-br from-primary/5 to-accent/5 p-8 rounded-2xl border border-primary/20 flex flex-col justify-center items-center text-center">
        <div class="size-16 rounded-full bg-primary/10 flex items-center justify-center mb-4">
          <span class="material-symbols-outlined text-3xl text-primary">rate_review</span>
        </div>
        <h3 class="font-bold text-slate-900 mb-2">¿Ya estudiaste con nosotros?</h3>
        <p class="text-sm text-slate-600 mb-4">Tu experiencia puede inspirar a otros dreamers a cumplir sus metas.</p>
        <a
          href="https://www.google.com/search?sca_esv=11b5b769ef94331f&rlz=1C5CHFA_enCO1138CO1138&sxsrf=ANbL-n4vzKIgZK3Be5jtEtkgFrEzVk21hg:1778115000882&si=AL3DRZEsmMGCryMMFSHJ3StBhOdZ2-6yYkXd_doETEE1OR-qObkgVesWmXKB2F9SpPSrwKQO-OBjfwr_9_l4Jv0juNZLHtzNiP4jUOqtFqZ5pJNEb6IWrqp4sbB7-GiPSPMMXZRQHQ1CXFjgQsGAObBPPCB37ox75g%3D%3D&q=Global+Dreamers+Opiniones&sa=X&ved=2ahUKEwj9gP3H-qWUAxWMQTABHYbDL_AQ0bkNegQINRAF&biw=1470&bih=801&dpr=2&sei=7-H7aaukHvWIwbkPydXCgA8#lrd=0xaedcaa5b364cbf07:0x95668c9c159166ee,3,,,,"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-primary/90 transition-colors"
        >
          <span class="material-symbols-outlined text-sm">rate_review</span>
          Dejar mi testimonio
        </a>
      </div>
    </div>

    <!-- Trust Badges -->
    <div class="mt-16 flex flex-wrap justify-center gap-8 items-center">
      <div class="flex items-center gap-2 text-slate-500">
        <span class="material-symbols-outlined text-primary">verified</span>
        <span class="text-sm">Agentes certificados</span>
      </div>
      <div class="flex items-center gap-2 text-slate-500">
        <span class="material-symbols-outlined text-primary">support_agent</span>
        <span class="text-sm">Soporte 24/7</span>
      </div>
      <div class="flex items-center gap-2 text-slate-500">
        <span class="material-symbols-outlined text-primary">emoji_events</span>
        <span class="text-sm">15+ años de experiencia</span>
      </div>
    </div>
  </div>
</section>

<style>
  .line-clamp-4 {
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
