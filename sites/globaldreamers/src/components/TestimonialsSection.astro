---
const testimonials = [
  { 
    quote: 'Gracias a la agencia Global Dreamers, me ayudaron mucho con mi trámite de visa y sobre todo siempre resolvieron cada duda que tuve.',
    name: 'David Duque T',
    role: 'Estudiante en Australia',
    initial: 'D'
  },
  { 
    quote: 'Excelente servicio de principio a fin. Me guiaron en la elección de la ciudad, el curso de inglés y todo el proceso de la visa. Estoy muy agradecida.',
    name: 'María Fernanda López',
    role: 'Estudiante en Melbourne',
    initial: 'M'
  },
  { 
    quote: 'Llevaba años queriendo estudiar en Australia pero no sabía por dónde empezar. Global Dreamers hizo todo sencillo y hoy estoy viviendo mi sueño.',
    name: 'Carlos Andrés Ruiz',
    role: 'Estudiante en Sydney',
    initial: 'C'
  },
  { 
    quote: 'La asesoría personalizada hizo la diferencia. No es una agencia más, realmente se preocupan por cada detalle de tu viaje y estadía.',
    name: 'Ana Lucía Gómez',
    role: 'Estudiante en Brisbane',
    initial: 'A'
  },
  { 
    quote: 'Mi experiencia con Global Dreamers fue increíble. Desde el primer contacto hasta mi llegada a Australia, siempre estuvieron pendientes de todo.',
    name: 'Juan Pablo Martínez',
    role: 'Estudiante en Perth',
    initial: 'J'
  },
];
---

<section class="py-20 overflow-hidden bg-slate-50" id="testimonios">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center mb-4 text-slate-900">Historias Reales de Nuestros Dreamers</h2>
    <p class="text-center text-slate-600 mb-12 max-w-2xl mx-auto">
      Cada día más estudiantes cumplen su sueño de estudiar en el exterior. 
      Estas son las experiencias de quienes confiaron en nosotros.
    </p>
    
    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.slice(0, 3).map((t) => (
        <div class="bg-white p-8 rounded-2xl shadow-lg border border-slate-100">
          <div class="flex gap-1 text-yellow-400 mb-4">
            {[1,2,3,4,5].map(() => (
              <span class="material-symbols-outlined fill-1 text-xl">star</span>
            ))}
          </div>
          <p class="italic text-slate-600 mb-6">"{t.quote}"</p>
          <div class="flex items-center gap-4">
            <div class="size-12 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center text-white font-bold text-lg">
              {t.initial}
            </div>
            <div>
              <p class="font-bold text-slate-900">{t.name}</p>
              <p class="text-xs text-slate-500 uppercase">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
    
    {/* Segunda fila - 2 testimonios + CTA */}
    <div class="grid md:grid-cols-3 gap-8 mt-8">
      {testimonials.slice(3, 5).map((t) => (
        <div class="bg-white p-8 rounded-2xl shadow-lg border border-slate-100">
          <div class="flex gap-1 text-yellow-400 mb-4">
            {[1,2,3,4,5].map(() => (
              <span class="material-symbols-outlined fill-1 text-xl">star</span>
            ))}
          </div>
          <p class="italic text-slate-600 mb-6">"{t.quote}"</p>
          <div class="flex items-center gap-4">
            <div class="size-12 rounded-full bg-gradient-to-br from-primary to-accent flex items-center justify-center text-white font-bold text-lg">
              {t.initial}
            </div>
            <div>
              <p class="font-bold text-slate-900">{t.name}</p>
              <p class="text-xs text-slate-500 uppercase">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
      
      {/* Call to Action - Dejar Testimonio */}
      <div class="bg-gradient-to-br from-primary/5 to-accent/5 p-8 rounded-2xl border border-primary/20 flex flex-col justify-center items-center text-center">
        <div class="size-16 rounded-full bg-primary/10 flex items-center justify-center mb-4">
          <span class="material-symbols-outlined text-3xl text-primary">rate_review</span>
        </div>
        <h3 class="font-bold text-slate-900 mb-2">¿Ya estudiaste con nosotros?</h3>
        <p class="text-sm text-slate-600 mb-4">Tu experiencia puede inspirar a otros dreamers a cumplir sus metas.</p>
        <a 
          href="https://wa.me/61449159849?text=Hola%2C%20quiero%20compartir%20mi%20testimonio%20sobre%20mi%20experiencia%20con%20Global%20Dreamers" 
          target="_blank"
          class="inline-flex items-center gap-2 bg-primary text-white px-4 py-2 rounded-full text-sm font-medium hover:bg-primary/90 transition-colors"
        >
          <span class="material-symbols-outlined text-sm">edit</span>
          Dejar mi testimonio
        </a>
      </div>
    </div>
    
    {/* Trust Badges */}
    <div class="mt-12 flex flex-wrap justify-center gap-8 items-center">
      <div class="flex items-center gap-2 text-slate-500">
        <span class="material-symbols-outlined text-primary">verified</span>
        <span class="text-sm">Agentes certificados</span>
      </div>
      <div class="flex items-center gap-2 text-slate-500">
        <span class="material-symbols-outlined text-primary">support_agent</span>
        <span class="text-sm">Soporte 24/7</span>
      </div>
      <div class="flex items-center gap-2 text-slate-500">
        <span class="material-symbols-outlined text-primary">emoji_events</span>
        <span class="text-sm">+5 años de experiencia</span>
      </div>
    </div>
  </div>
</section>
