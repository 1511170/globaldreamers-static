---


const heroImage = '/images/hero.webp';
const avatars = [
  '/images/testimonial-camila.png',
  '/images/testimonial-marcos.png', 
  '/images/testimonial-sofia.png',
];
---

<section class="relative py-12 lg:py-24 overflow-hidden bg-white">
  <!-- Gradient Orbs de fondo -->
  <div class="gradient-orb orb-1 opacity-30"></div>
  <div class="gradient-orb orb-2 opacity-20" style="width: 300px; height: 300px; background: linear-gradient(135deg, #22d3ee, #0ea5e9); top: 60%; left: 10%;"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="z-10">
        <!-- Badge con animación -->
        <div class="hero-badge animate-fade-up inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold mb-6 hover-glow cursor-default">
          <span class="material-symbols-outlined text-sm">verified</span>
          <span class="counter-value" data-value="99">99</span>% Tasa de Aprobación de Visas
        </div>
        
        <!-- Título con animación -->
        <h1 class="hero-title-animate text-4xl md:text-6xl font-black leading-tight mb-6 text-slate-900">
          Estudia, Trabaja y Vive en el Exterior — <span class="text-primary">Hacemos Tu Sueño Realidad</span>
        </h1>
        
        <!-- Subtítulo con animación -->
        <p class="hero-subtitle-animate text-lg text-slate-600 mb-8 max-w-lg">
          Asesoría 100% gratuita para que logres tu meta internacional. Más de 500 estudiantes ya están viviendo su experiencia.
        </p>
        
        <!-- CTAs con efectos -->
        <div class="hero-cta-animate flex flex-col sm:flex-row gap-4">
          <a
            href="/elige-tu-destino"
            class="inline-flex items-center gap-2 bg-primary text-white px-8 py-4 rounded-xl font-bold text-lg shadow-xl shadow-primary/30 hover:shadow-2xl hover:shadow-primary/40 transition-all"
          >
            Elige tu Destino Ideal
            <span class="arrow-icon material-symbols-outlined ml-2 transition-transform group-hover:translate-x-1">arrow_forward</span>
          </a>
          <div class="flex items-center gap-3 px-4">
            <div class="flex -space-x-2">
              {avatars.map((src, i) => (
                <img 
                  alt={`Student ${i + 1}`} 
                  class="size-10 rounded-full border-2 border-white object-cover hover-scale transition-transform cursor-pointer" 
                  src={src} 
                  loading="lazy" 
                />
              ))}
            </div>
            <span class="text-sm font-medium text-slate-500">+500 estudiantes felices</span>
          </div>
        </div>
      </div>
      
      <!-- Imagen con efectos -->
      <div class="relative">
        <div class="rounded-3xl overflow-hidden shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-500">
          <img 
            alt="Estudiantes latinos en los 11 destinos de Global Dreamers: Canadá, Malta, Dubai, Reino Unido, Nueva Zelanda, Irlanda, España, Alemania, Italia, Estados Unidos y Australia" 
            class="w-full h-auto object-cover" 
            src={heroImage} 
            loading="eager" 
          />
        </div>
        
        <!-- Badge flotante con animación -->
        <div class="animate-float glass-card absolute -bottom-6 -left-6 p-6 rounded-2xl shadow-xl border border-slate-100 -rotate-3 hover-lift cursor-default">
          <p class="text-primary font-bold text-3xl">100%</p>
          <p class="text-xs font-semibold text-slate-500">Gratuito para Estudiantes</p>
        </div>
        
        <!-- Badge adicional -->
        <div class="animate-float-delayed glass-card absolute -top-4 -right-4 p-4 rounded-xl shadow-lg border border-slate-100 hover-scale cursor-default">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-primary text-2xl">rocket_launch</span>
            <div>
              <p class="font-bold text-slate-900">+15K</p>
              <p class="text-xs text-slate-500">Visas gestionadas</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
