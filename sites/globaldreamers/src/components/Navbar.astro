---
import { destinations } from '../data/destinations';

interface Props {
  ctaText?: string;
}

const { ctaText = 'Agendar Asesoría' } = Astro.props;

// Navegación principal del sitio
const mainNav = [
  { label: 'Inicio', href: '/', icon: 'home' },
  { label: 'Destinos', href: '/#destinos', hasDropdown: true, icon: 'public' },
  { label: 'Servicios', href: '/servicios', hasDropdown: true, icon: 'work' },
  { label: 'Nosotros', href: '/nosotros', icon: 'group' },
  { label: 'Blog', href: '/blog', icon: 'article' },
];

// Servicios para el dropdown
const servicesNavItems = [
  { label: 'Asesoría Gratuita', href: '/asesoria-gratuita', icon: 'support_agent', desc: 'Consulta personalizada sin costo' },
  { label: 'Gestión de Visa', href: '/servicios#visa', icon: 'description', desc: 'Trámite completo de visas estudiante' },
  { label: 'Selección de Cursos', href: '/servicios#cursos', icon: 'school', desc: 'Encuentra el programa ideal' },
  { label: 'Alojamiento', href: '/servicios#alojamiento', icon: 'apartment', desc: 'Homestay y residencias' },
  { label: 'Acompañamiento', href: '/servicios#acompanamiento', icon: 'flight_takeoff', desc: 'Apoyo desde tu país al destino' },
  { label: 'Seguro Médico', href: '/servicios#seguro', icon: 'health_and_safety', desc: 'Cobertura internacional' },
];

// Mapa de códigos de país para banderas SVG
const countryCodes: Record<string, string> = {
  'canada': 'ca',
  'malta': 'mt',
  'dubai': 'ae',
  'reino-unido': 'gb',
  'nueva-zelanda': 'nz',
  'irlanda': 'ie',
  'espana': 'es',
  'alemania': 'de',
  'italia': 'it',
  'estados-unidos': 'us',
  'australia': 'au',
};

// Destinos para el dropdown (todos los disponibles)
const destNavItems = destinations.map((d) => ({ 
  label: d.name, 
  href: d.canonical,
  code: countryCodes[d.country] || 'un'
}));
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-slate-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      {/* Logo */}
      <a href="/" class="flex items-center shrink-0">
        <img 
          src="/images/logo-globaldreamers-color.png" 
          alt="Global Dreamers"
          class="h-12 w-auto"
        />
      </a>

      {/* Desktop Navigation */}
      <nav class="hidden lg:flex items-center gap-1">
        <a 
          href="/"
          class="flex items-center gap-1.5 px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors rounded-lg hover:bg-slate-50"
        >
          <span class="material-symbols-outlined text-base">home</span>
          Inicio
        </a>

        {/* Destinos Dropdown */}
        <div class="relative group">
          <button class="flex items-center gap-1.5 px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors rounded-lg hover:bg-slate-50">
            <span class="material-symbols-outlined text-base">public</span>
            Destinos
            <span class="material-symbols-outlined text-base transition-transform group-hover:rotate-180">expand_more</span>
          </button>
          <div class="absolute left-0 mt-1 w-[420px] bg-white border border-slate-200 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-3">
            <div class="px-4 py-2 text-xs font-semibold text-slate-400 uppercase tracking-wider border-b border-slate-100 mb-2">
              Elige tu destino
            </div>
            <div class="grid grid-cols-2 gap-1 px-2">
              {destNavItems.map((dest) => (
                <a
                  href={dest.href}
                  class="flex items-center gap-3 px-3 py-2.5 text-sm text-slate-700 hover:bg-slate-50 hover:text-primary transition-colors rounded-lg"
                >
                  <img 
                    src={`https://kapowaz.github.io/circle-flags/flags/${dest.code}.svg`}
                    alt={dest.label}
                    class="w-5 h-5 rounded-full flex-shrink-0 object-cover"
                    loading="lazy"
                  />
                  <span class="font-medium">{dest.label}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        {/* Servicios Dropdown */}
        <div class="relative group">
          <button class="flex items-center gap-1.5 px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors rounded-lg hover:bg-slate-50">
            <span class="material-symbols-outlined text-base">work</span>
            Servicios
            <span class="material-symbols-outlined text-base transition-transform group-hover:rotate-180">expand_more</span>
          </button>
          <div class="absolute left-0 mt-1 w-[380px] bg-white border border-slate-200 rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-3">
            <div class="px-4 py-2 text-xs font-semibold text-slate-400 uppercase tracking-wider border-b border-slate-100 mb-2">
              Nuestros servicios
            </div>
            <div class="flex flex-col gap-1 px-2">
              {servicesNavItems.map((service) => (
                <a
                  href={service.href}
                  class="flex items-start gap-3 px-3 py-3 text-sm text-slate-700 hover:bg-slate-50 hover:text-primary transition-colors rounded-lg group/item"
                >
                  <span class="material-symbols-outlined text-primary text-xl mt-0.5 group-hover/item:scale-110 transition-transform">
                    {service.icon}
                  </span>
                  <div class="flex flex-col">
                    <span class="font-semibold">{service.label}</span>
                    <span class="text-xs text-slate-500">{service.desc}</span>
                  </div>
                </a>
              ))}
            </div>
            <div class="px-2 pt-2 mt-2 border-t border-slate-100">
              <a
                href="/servicios"
                class="flex items-center justify-center gap-2 px-3 py-2 text-sm font-bold text-primary hover:bg-primary/5 transition-colors rounded-lg"
              >
                Ver todos los servicios
                <span class="material-symbols-outlined text-base">arrow_forward</span>
              </a>
            </div>
          </div>
        </div>

        <a 
          href="/nosotros"
          class="flex items-center gap-1.5 px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors rounded-lg hover:bg-slate-50"
        >
          <span class="material-symbols-outlined text-base">group</span>
          Nosotros
        </a>

        <a 
          href="/blog"
          class="flex items-center gap-1.5 px-3 py-2 text-sm font-semibold text-slate-600 hover:text-primary transition-colors rounded-lg hover:bg-slate-50"
        >
          <span class="material-symbols-outlined text-base">article</span>
          Blog
        </a>
      </nav>

      {/* CTA y Mobile Menu Button */}
      <div class="flex items-center gap-3">
        <a
          href="/asesoria-gratuita"
          class="hidden md:flex bg-primary text-white text-sm font-bold py-2 px-5 rounded-lg hover:bg-primary/90 transition-all shadow-lg shadow-primary/20 hover:shadow-primary/30"
        >
          {ctaText}
        </a>
        
        <button 
          id="mobile-menu-btn" 
          class="lg:hidden text-slate-700 p-2 rounded-lg hover:bg-slate-100 transition-colors" 
          aria-label="Abrir menú" 
          aria-expanded="false"
        >
          <span id="icon-open" class="material-symbols-outlined text-2xl">menu</span>
          <span id="icon-close" class="material-symbols-outlined text-2xl hidden">close</span>
        </button>
      </div>
    </div>
  </div>

  {/* Mobile Menu */}
  <div id="mobile-menu" class="hidden lg:hidden border-t border-slate-200 bg-white">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-4">
      {/* Links principales */}
      <nav class="space-y-1">
        <a 
          href="/"
          class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-slate-700 hover:text-primary hover:bg-slate-50 rounded-lg transition-colors"
        >
          <span class="material-symbols-outlined text-primary">home</span>
          Inicio
        </a>
        <a 
          href="/nosotros"
          class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-slate-700 hover:text-primary hover:bg-slate-50 rounded-lg transition-colors"
        >
          <span class="material-symbols-outlined text-primary">group</span>
          Nosotros
        </a>
        <a 
          href="/blog"
          class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-slate-700 hover:text-primary hover:bg-slate-50 rounded-lg transition-colors"
        >
          <span class="material-symbols-outlined text-primary">article</span>
          Blog
        </a>
      </nav>

      {/* Servicios en móvil */}
      <div class="pt-4 border-t border-slate-100">
        <p class="px-4 text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">
          Servicios
        </p>
        <div class="space-y-1">
          {servicesNavItems.slice(0, 4).map((service) => (
            <a
              href={service.href}
              class="flex items-center gap-3 px-4 py-2 text-sm text-slate-700 hover:text-primary hover:bg-slate-50 rounded-lg transition-colors"
            >
              <span class="material-symbols-outlined text-primary text-lg">{service.icon}</span>
              {service.label}
            </a>
          ))}
        </div>
        <a 
          href="/servicios" 
          class="block px-4 py-2 mt-2 text-sm font-semibold text-primary hover:bg-slate-50 rounded-lg transition-colors"
        >
          Ver todos los servicios →
        </a>
      </div>

      {/* Destinos en móvil */}
      <div class="pt-4 border-t border-slate-100">
        <p class="px-4 text-xs font-semibold text-slate-400 uppercase tracking-wider mb-2">
          Destinos Populares
        </p>
        <div class="grid grid-cols-2 gap-1">
          {destNavItems.slice(0, 6).map((dest) => (
            <a
              href={dest.href}
              class="px-4 py-2 text-sm text-slate-700 hover:text-primary hover:bg-slate-50 rounded-lg transition-colors"
            >
              {dest.label}
            </a>
          ))}
        </div>
        <a 
          href="/#destinos" 
          class="block px-4 py-2 mt-2 text-sm font-semibold text-primary hover:bg-slate-50 rounded-lg transition-colors"
        >
          Ver todos los destinos →
        </a>
      </div>

      {/* CTA en móvil */}
      <div class="pt-4 border-t border-slate-100">
        <a 
          href="/asesoria-gratuita" 
          class="flex items-center justify-center w-full py-3 bg-primary text-white text-sm font-bold rounded-lg shadow-lg"
        >
          {ctaText}
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('icon-open');
    const iconClose = document.getElementById('icon-close');
    
    if (!btn || !menu) return;
    
    btn.addEventListener('click', function() {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      if (iconOpen) iconOpen.classList.toggle('hidden', !isOpen);
      if (iconClose) iconClose.classList.toggle('hidden', isOpen);
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
    
    // Cerrar menú al hacer clic en un link
    menu.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        menu.classList.add('hidden');
        if (iconOpen) iconOpen.classList.remove('hidden');
        if (iconClose) iconClose.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>
